  \draw[->, color=black, line width=1pt] (O) -- (Y) node[above] {$y$};
  \draw[->, color=red!80!black, line width=1pt] (O) -- (Yhat) node[below, yshift=-6mm] {$\hat{y} = X\hat{\beta} = P_X y$};
