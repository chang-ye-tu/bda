\section{The OLS Setup}\label{sec:2.1}

\subsection{Linear-algebra preliminaries}\label{sec:2.1.1}

\begin{definition}[Linear-algebra vocabulary]\label{def:linalg-prelim}
A nonempty \(V \subseteq \mathbb{R}^n\) is a \emph{subspace} if it is closed under linear combinations (so \(0 \in V\), \(u + v \in V\), \(\alpha u \in V\) for all \(u, v \in V, \alpha \in \mathbb{R}\)). For \(A \in \mathbb{R}^{m \times n}\), viewed as the linear map \(\mathbb{R}^n \to \mathbb{R}^m\), \(v \mapsto Av\):

\vspace{2mm}
{\centering\footnotesize
\begin{tabular}{l l}
\toprule
\textbf{Concept} & \textbf{Definition} \\
\midrule
Span of \(v_1, \ldots, v_k\) & \(\{\sum_i c_i v_i : c_i \in \mathbb{R}\}\); always a subspace \\
Linear independence & \(\sum_i c_i v_i = 0 \Rightarrow c_i = 0\) for every \(i\) \\
Basis of \(V\) & linearly independent spanning set \\
Dimension \(\dim V\) & cardinality of any basis (independent of choice) \\
Image \(\img(A) = \col(A)\) & \(\{Av : v \in \mathbb{R}^n\}\) = span of columns; subspace of \(\mathbb{R}^m\) \\
Kernel \(\ker(A)\) & \(\{v \in \mathbb{R}^n : Av = 0\}\); subspace of \(\mathbb{R}^n\) \\
Rank \(\rk(A)\) & \(\dim \img(A)\) \\
Nullity \(\nul(A)\) & \(\dim \ker(A)\) \\
Orthogonal vectors & \(u \perp v \;\Leftrightarrow\; u^\top v = 0\) \\
Orthogonal subspaces & \(U \perp V \;\Leftrightarrow\; u^\top v = 0\) for all \(u \in U, v \in V\) \\
Orthogonal complement \(V^\perp\) & \(\{u : u \perp v\ \forall v \in V\}\); subspace of \(\mathbb{R}^n\) \\
Orthogonal direct sum & \(\mathbb{R}^n = V \oplus V^\perp\); every \(x = v + u\) uniquely, \(\dim V + \dim V^\perp = n\) \\
\bottomrule
\end{tabular}\par}
\vspace{2mm}
\end{definition}

\begin{theorem}[Rank--nullity]\label{thm:rank-nullity}
Let \(A \in \mathbb{R}^{m \times n}\), viewed as a linear map \(\mathbb{R}^n \to \mathbb{R}^m\). Then
\[
  n \;=\; \rk(A) + \nul(A),
\]
where \(\rk(A) := \dim\,\img(A)\) and \(\nul(A) := \dim\ker(A)\).
\end{theorem}

\begin{proof}
Let \(k = \nul(A)\) and fix a basis \(\{v_1, \ldots, v_k\}\) of \(\ker(A)\); extend to a basis \(\{v_1, \ldots, v_k, u_1, \ldots, u_{n-k}\}\) of \(\mathbb{R}^n\). It suffices to show that \(\{Au_1, \ldots, Au_{n-k}\}\) is a basis of \(\img(A)\): then \(\rk(A) = n-k\), giving \(n = k + (n-k) = \nul(A) + \rk(A)\).

\textbf{Spanning.} For any \(w = Av \in \img(A)\), write \(v = \sum_i c_i v_i + \sum_j d_j u_j\). Each \(v_i \in \ker(A)\), so \(Av_i = 0\), and
\[
  Av \;=\; \sum_i c_i \cdot 0 \,+\, \sum_j d_j Au_j \;=\; \sum_j d_j Au_j.
\]
Hence \(\{Au_j\}\) spans \(\img(A)\).

\textbf{Linear independence.} Suppose \(\sum_j d_j Au_j = 0\). Then \(A\bigl(\sum_j d_j u_j\bigr) = 0\), so \(\sum_j d_j u_j \in \ker(A)\), which we expand in the kernel basis as \(\sum_j d_j u_j = \sum_i c_i v_i\) for some \(c_i\). Rearranging,
\[
  \sum_j d_j u_j \,-\, \sum_i c_i v_i \;=\; 0.
\]
Linear independence of the extended basis \(\{v_i\} \cup \{u_j\}\) forces every \(c_i = 0\) and every \(d_j = 0\); the \(\{Au_j\}\) are therefore linearly independent.
\end{proof}

\begin{definition}[Matrix types]\label{def:matrix-types}
For \(A \in \mathbb{R}^{p \times p}\):

\vspace{2mm}
{\centering\footnotesize
\begin{tabular}{l l}
\toprule
\textbf{Concept} & \textbf{Definition} \\
\midrule
Symmetric matrix & \(A^\top = A\) \\
Diagonal matrix \(\diag(\lambda_1, \ldots, \lambda_p)\) & off-diagonal entries zero; \((i,i)\)-entry equal to \(\lambda_i\) \\
Orthogonal matrix \(Q\) & square with \(Q^\top Q = QQ^\top = I_p\) (columns orthonormal) \\
Positive semidefinite \(A \succcurlyeq 0\) & symmetric \(A\) with \(v^\top A v \geqslant 0\) for every \(v \in \mathbb{R}^p\) \\
Positive definite \(A \succ 0\) & symmetric \(A\) with \(v^\top A v > 0\) for every \(v \in \mathbb{R}^p, v \neq 0\) \\
\bottomrule
\end{tabular}\par}
\vspace{2mm}
\end{definition}

\begin{lemma}[Left inverse equals right inverse for square matrices]\label{lem:left-right-inv}
For square \(Q \in \mathbb{R}^{p \times p}\), if \(Q^\top Q = I_p\) then \(Q\) is invertible with \(Q^{-1} = Q^\top\); in particular, \(QQ^\top = I_p\). (So defining an orthogonal matrix by orthonormal columns automatically gives orthonormal rows.)
\end{lemma}

\begin{proof}
\(Q^\top Q = I_p\) implies \(\ker(Q)\) is trivial: if \(Qv = 0\), then \(v = Q^\top Q v = Q^\top \cdot 0 = 0\). By Theorem~\ref{thm:rank-nullity}, \(\rk(Q) = p - \nul(Q) = p\). Since \(Q\) is \(p \times p\) with rank \(p\), \(Q : \mathbb{R}^p \to \mathbb{R}^p\) is bijective, so \(Q^{-1}\) exists. Right-multiplying \(Q^\top Q = I_p\) by \(Q^{-1}\) gives \(Q^\top = Q^{-1}\); hence \(QQ^\top = QQ^{-1} = I_p\).
\end{proof}

\begin{definition}[Eigenvalue and eigenvector]\label{def:eigenvalue}
For symmetric \(A \in \mathbb{R}^{p \times p}\), \(\lambda \in \mathbb{R}\) is an \emph{eigenvalue} with \emph{eigenvector} \(v \in \mathbb{R}^p, v \neq 0\), if \(Av = \lambda v\). (Reality of every eigenvalue of a real symmetric \(A\) is part of the spectral theorem proven below.)
\end{definition}

\begin{theorem}[Spectral theorem]\label{thm:spectral}
Every symmetric \(A \in \mathbb{R}^{p \times p}\) admits an \emph{orthogonal diagonalization}
\[
  A \;=\; Q \Lambda Q^\top, \qquad \Lambda = \diag(\lambda_1, \ldots, \lambda_p),\ Q^\top Q = QQ^\top = I_p,
\]
with real eigenvalues \(\lambda_j\) and orthonormal eigenvectors \(q_1, \ldots, q_p\) (the columns of \(Q\)). When \(A \succ 0\), all \(\lambda_j > 0\) and \(A^{-1} = Q\diag(\lambda_j^{-1}) Q^\top\).
\end{theorem}

\begin{proof}
We construct \(q_1, \ldots, q_p\) iteratively as solutions of constrained Rayleigh-quotient maximizations. Set \(W_1 := \mathbb{R}^p\); for \(j = 1, 2, \ldots, p\), define
\[
  q_j \;:=\; \arg\max_{x \in W_j,\ \|x\| = 1} x^\top A x, \qquad \lambda_j \;:=\; q_j^\top A q_j, \qquad W_{j+1} \;:=\; W_j \cap \{q_j\}^\perp.
\]

\textbf{Step 1: \(q_j\) exists.} \(\{x \in W_j : \|x\| = 1\}\) is closed and bounded in finite-dimensional \(\mathbb{R}^p\), hence compact (Heine--Borel); \(x \mapsto x^\top A x\) is continuous, so by the Weierstrass extreme value theorem the maximum is attained.

\textbf{Step 2: \(q_j\) is an eigenvector with eigenvalue \(\lambda_j\).} Unfolding the recursion \(W_{j+1} = W_j \cap \{q_j\}^\perp\) starting from \(W_1 = \mathbb{R}^p\) gives
\[
  W_j \;=\; \mathrm{span}(q_1, \ldots, q_{j-1})^\perp, \qquad W_{j+1} \;=\; \mathrm{span}(q_1, \ldots, q_j)^\perp,
\]
so \(W_j^\perp = \mathrm{span}(q_1, \ldots, q_{j-1})\) and \(W_{j+1}^\perp = \mathrm{span}(q_1, \ldots, q_j)\).

For any direction \(w \in W_{j+1}\) (so \(w \in W_j\) and \(w \perp q_j\)), the curve
\[
  x(t) \;:=\; \frac{q_j + tw}{\|q_j + tw\|}, \quad t \in (-\delta, \delta) \text{ small},
\]
stays in \(W_j\) (linear combinations of \(q_j, w \in W_j\)) and on the unit sphere by construction, so the function \(g(t) := x(t)^\top A x(t)\) attains its maximum at \(t = 0\). Hence \(g'(0) = 0\). Using \(\|q_j\| = 1\), \(q_j \perp w\), and \(A^\top = A\), expand the numerator and denominator:
\begin{align*}
  (q_j + tw)^\top A (q_j + tw) &= q_j^\top A q_j + 2t (Aq_j)^\top w + t^2 w^\top A w \;=\; \lambda_j + 2t (Aq_j)^\top w + O(t^2), \\
  \|q_j + tw\|^2 &= 1 + t^2 \|w\|^2.
\end{align*}
Their ratio gives \(g(t) = \lambda_j + 2t (Aq_j)^\top w + O(t^2)\), so
\[
  0 \;=\; g'(0) \;=\; 2 (A q_j)^\top w.
\]
Since this holds for every \(w \in W_{j+1}\), \(A q_j \in W_{j+1}^\perp = \mathrm{span}(q_1, \ldots, q_j)\). Write
\[
  A q_j \;=\; \lambda\, q_j + \sum_{i=1}^{j-1} \alpha_i\, q_i.
\]

To eliminate the \(\alpha_k\) for \(k < j\), take the inner product of both sides with \(q_k\):
\[
  q_k^\top A q_j \;=\; \lambda\,(q_k^\top q_j) + \sum_i \alpha_i\,(q_k^\top q_i) \;=\; \alpha_k,
\]
using orthonormality of \((q_1, \ldots, q_j)\). Independently, the previous iterations of the construction already produced \(A q_k = \lambda_k q_k\), so
\[
  q_k^\top A q_j \;=\; (A q_k)^\top q_j \;=\; \lambda_k\,(q_k^\top q_j) \;=\; 0,
\]
using \(A^\top = A\). Hence \(\alpha_k = 0\) for every \(k < j\), and \(A q_j = \lambda q_j\). Taking the inner product with \(q_j\) gives \(\lambda = q_j^\top A q_j = \lambda_j\), which is real since \(q_j^\top A q_j\) is a real expression.

\textbf{Step 3: \((q_1, \ldots, q_p)\) is an orthonormal basis of \(\mathbb{R}^p\).} \(\|q_j\| = 1\) by construction; \(q_j \perp q_i\) for every \(i < j\) by the constraint defining \(W_j\). The \(q_j\) are pairwise orthogonal unit vectors, and any \(p\) such vectors in \(\mathbb{R}^p\) form a basis.

\textbf{Step 4: Assemble.} Set \(Q := [q_1\ q_2\ \cdots\ q_p]\) and \(\Lambda := \diag(\lambda_1, \ldots, \lambda_p)\). Orthonormality of the columns gives \(Q^\top Q = QQ^\top = I_p\); the eigenvalue equations \(A q_j = \lambda_j q_j\) (\(j = 1, \ldots, p\)) read \(AQ = Q\Lambda\), and right-multiplying by \(Q^\top\) yields \(A = Q\Lambda Q^\top\).

\textbf{PSD case.} If \(A \succ 0\), then for each unit eigenvector \(q_j\), \(\lambda_j = q_j^\top A q_j > 0\); \(\Lambda^{-1} = \diag(\lambda_j^{-1})\) exists, and \((Q\Lambda Q^\top)(Q\Lambda^{-1} Q^\top) = Q\Lambda\Lambda^{-1} Q^\top = QQ^\top = I_p\), so \(A^{-1} = Q\Lambda^{-1} Q^\top\).
\end{proof}

The construction in the proof of Theorem~\ref{thm:spectral} defines each $q_j$ as the argmax of $x^\top A x$ over $\{x \in W_j : \|x\| = 1\}$. Reading this off as a numbered statement gives the Rayleigh-quotient characterization of every eigenvalue, used in Unit~7 \S 7.2 (PCA variance maximization) and the Eckart--Young proof.

\begin{theorem}[Rayleigh-quotient maxima]\label{thm:rayleigh}
Let \(A \in \mathbb{R}^{p \times p}\) be symmetric with eigenvalues \(\lambda_1 \geqslant \cdots \geqslant \lambda_p\) and orthonormal eigenvectors \(q_1, \ldots, q_p\) as in Theorem~\ref{thm:spectral}. Then
\[
\lambda_1 \;=\; \max_{x \neq \mathbf{0}}\, \frac{x^\top A x}{x^\top x} \;=\; \max_{\|x\| = 1} x^\top A x,
\]
attained at \(x = q_1\). For \(k = 2, \ldots, p\),
\[
\lambda_k \;=\; \max_{\substack{\|x\| = 1 \\ x \perp q_1, \ldots, q_{k-1}}} x^\top A x,
\]
attained at \(x = q_k\). Symmetrically, \(\lambda_p\) is the minimum of \(x^\top A x\) on the unit sphere, attained at \(q_p\).
\end{theorem}

\begin{proof}
Expand a unit vector \(x\) in the basis \(q_1, \ldots, q_p\): \(x = \sum_j c_j q_j\) with \(\sum_j c_j^2 = 1\). Using \(A q_j = \lambda_j q_j\) and orthonormality,
\[
x^\top A x \;=\; \sum_{j=1}^{p} c_j^2 \lambda_j,
\]
a convex combination of \(\lambda_1, \ldots, \lambda_p\), hence in \([\lambda_p, \lambda_1]\), with maximum \(\lambda_1\) at \(c_1 = 1\), \(c_2 = \cdots = c_p = 0\), i.e.\ \(x = q_1\). Homogeneity of the Rayleigh quotient $x^\top A x / x^\top x$ gives the unconstrained form. The constraint \(x \perp q_1, \ldots, q_{k-1}\) forces \(c_1 = \cdots = c_{k-1} = 0\), so \(x^\top A x = \sum_{j \geqslant k} c_j^2 \lambda_j \leqslant \lambda_k\), attained at \(x = q_k\). The minimum statement follows by applying the maximum to \(-A\) (eigenvalues \(-\lambda_p \geqslant \cdots \geqslant -\lambda_1\)).
\end{proof}

\subsection{Matrix model and classical assumptions}\label{sec:2.1.2}

\begin{definition}[Linear regression model and Gauss--Markov assumptions]\label{def:lin-model}
The \emph{linear regression model} is
\[
  y \;=\; X\beta + \varepsilon, \qquad y \in \mathbb{R}^n,\; X \in \mathbb{R}^{n \times p},\; \beta \in \mathbb{R}^p,\; \varepsilon \in \mathbb{R}^n,
\]
with \(X\)'s first column typically \(\mathbf{1}_n\) for an intercept. Linearity is in \(\beta\); columns of \(X\) may be nonlinear transforms (powers, logs, interactions) of raw features. The classical Gauss--Markov framework adds:

\vspace{2mm}
{\centering
\begin{tabular}{c l l}
\toprule
\textbf{ID} & \textbf{Statement} & \textbf{Yields} \\
\midrule
\Atarget{1} & \textbf{Linearity}: \(y = X\beta + \varepsilon\) for fixed \(\beta\) & the target \(\beta\) is well-defined \\
\Atarget{2} & \textbf{Full column rank}: \(\rk(X) = p\) & \(\hat\beta = (X^\top X)^{-1} X^\top y\) is unique \\
\Atarget{3} & \textbf{Exogeneity}: \(\expc[\varepsilon \mid X] = 0\) & \(\expc[\hat\beta \mid X] = \beta\) (unbiased) \\
\Atarget{4} & \textbf{Spherical errors}: \(\var(\varepsilon \mid X) = \sigma^2 I_n\) & \(\hat\beta\) is BLUE (Gauss--Markov) \\
\bottomrule
\end{tabular}\par}
\vspace{2mm}
\end{definition}

\subsection{Normal equations and the OLS estimator}\label{sec:2.1.3}

OLS minimizes the squared-error objective
\[
  Q(\beta) \;=\; \|y - X\beta\|^2 \;=\; (y - X\beta)^\top (y - X\beta).
\]

\begin{lemma}[Rank of \(X^\top X\)]\label{lem:rank-xtx}
For any \(X \in \mathbb{R}^{n \times p}\), \(\rk(X^\top X) = \rk(X)\). Under \Aref{2}, \(X^\top X\) is therefore invertible.
\end{lemma}

\begin{proof}
\(X\) and \(X^\top X\) share their null space: \(Xv = 0 \Rightarrow X^\top X v = 0\) by left-multiplying by \(X^\top\); conversely \(X^\top X v = 0 \Rightarrow v^\top X^\top X v = \|Xv\|^2 = 0 \Rightarrow Xv = 0\). Both \(X : \mathbb{R}^p \to \mathbb{R}^n\) and \(X^\top X : \mathbb{R}^p \to \mathbb{R}^p\) have input dimension \(p\) and the same nullity, so Theorem~\ref{thm:rank-nullity} applied to each gives
\[
  \rk(X) \;=\; p - \nul(X) \;=\; p - \nul(X^\top X) \;=\; \rk(X^\top X).
\]
Under \Aref{2}, \(\rk(X) = p\); hence \(X^\top X\) is a full-rank \(p \times p\) matrix and is invertible.
\end{proof}

\begin{lemma}[Gradients of linear and quadratic forms]\label{lem:matrix-calc}
For \(\beta \in \mathbb{R}^p\), constant \(a \in \mathbb{R}^p\), and symmetric \(A \in \mathbb{R}^{p \times p}\), with \(D(\cdot)\) denoting the row-vector gradient (\(D f = (\partial f/\partial \beta_1, \ldots, \partial f/\partial \beta_p)\)):
\[
  D(a^\top \beta) \;=\; a^\top, \qquad D(\beta^\top A \beta) \;=\; 2\beta^\top A.
\]
\end{lemma}

\begin{proof}
For the linear form, \(a^\top \beta = \sum_i a_i \beta_i\), so \(\partial(a^\top\beta)/\partial\beta_k = a_k\), giving \(D(a^\top\beta) = a^\top\).

For the quadratic form, \(\beta^\top A \beta = \sum_{i, j} A_{ij}\, \beta_i \beta_j\). Differentiate term by term:
\[
  \frac{\partial(\beta^\top A \beta)}{\partial \beta_k} \;=\; \sum_j A_{kj} \beta_j + \sum_i A_{ik} \beta_i \;=\; \sum_j (A_{kj} + A_{jk}) \beta_j \;=\; 2 \sum_j A_{kj} \beta_j \;=\; 2 (A\beta)_k,
\]
using \(A_{jk} = A_{kj}\) (symmetry). Hence \(D(\beta^\top A \beta) = 2(A\beta)^\top = 2\beta^\top A\) (again by symmetry).
\end{proof}

\begin{theorem}[OLS estimator]\label{thm:ols-estimator}
Under \Aref{2}, \(Q\) has a unique minimizer
\[
  \hat\beta \;=\; (X^\top X)^{-1} X^\top y.
\]
\end{theorem}

\begin{proof}
\textbf{Step 1: Expand.} Using \(y^\top X\beta = \beta^\top X^\top y\) (a scalar equals its transpose),
\[
  Q(\beta) \;=\; y^\top y - 2\beta^\top X^\top y + \beta^\top X^\top X \beta.
\]

\textbf{Step 2: First-order condition.} Apply Lemma~\ref{lem:matrix-calc} with \(a = X^\top y\) and \(A = X^\top X\):
\[
  DQ(\beta) \;=\; -2\, y^\top X + 2\,\beta^\top X^\top X.
\]
Setting \(DQ(\beta) = 0\) and transposing gives the \emph{normal equation}
\[
  X^\top X \hat\beta \;=\; X^\top y.
\]

\textbf{Step 3: Solve.} By Lemma~\ref{lem:rank-xtx} and \Aref{2}, \(X^\top X\) is invertible, so
\[
  \hat\beta \;=\; (X^\top X)^{-1} X^\top y.
\]

\textbf{Step 4: Second-order condition.} The Hessian \(\nabla^2 Q = 2 X^\top X\). For any \(v \neq 0\), under \Aref{2}, \(v^\top X^\top X v = \|Xv\|^2 > 0\), so \(X^\top X \succ 0\). Hence \(Q\) is strictly convex on \(\mathbb{R}^p\) and \(\hat\beta\) is the unique global minimum.
\end{proof}

\subsection{Geometric reading: orthogonal projection}\label{sec:2.1.4}

Under \Aref{2}, \(\dim \col(X) = \rk(X) = p\), so OLS searches for the closest point in a \(p\)-dimensional subspace of \(\mathbb{R}^n\). The resulting fit has a clean geometric description.

\begin{theorem}[Orthogonality characterization of OLS]\label{thm:orth-char}
For \(\hat y \in \col(X)\), the following are equivalent:
\begin{enumerate}[leftmargin=2.4em,itemsep=2pt,topsep=2pt]
\item[(i)]   \(\hat y\) minimizes \(\|y - \tilde y\|^2\) over \(\tilde y \in \col(X)\);
\item[(ii)]  \(y - \hat y \perp \col(X)\), i.e.\ \(v^\top(y - \hat y) = 0\) for every \(v \in \col(X)\);
\item[(iii)] \(X^\top(y - \hat y) = 0\).
\end{enumerate}
The minimizer is unique under \Aref{2} and equals \(\hat y = X\hat\beta\) with \(\hat\beta = (X^\top X)^{-1} X^\top y\).
\end{theorem}

\begin{proof}
\textbf{(ii) \(\Leftrightarrow\) (iii).} The columns of \(X\) span \(\col(X)\), so \(y - \hat y\) is orthogonal to every \(v \in \col(X)\) iff orthogonal to each column iff \(X^\top(y - \hat y) = 0\).

\textbf{(ii) \(\Rightarrow\) (i).} Let \(\tilde y \in \col(X)\). Since \(\col(X)\) is a subspace, \(\hat y - \tilde y \in \col(X)\), so \((y - \hat y) \perp (\hat y - \tilde y)\). Pythagoras applied to \(y - \tilde y = (y - \hat y) + (\hat y - \tilde y)\) gives
\[
  \|y - \tilde y\|^2 \;=\; \|y - \hat y\|^2 + \|\hat y - \tilde y\|^2 \;\geqslant\; \|y - \hat y\|^2,
\]
with equality iff \(\tilde y = \hat y\).

\textbf{(i) \(\Rightarrow\) (ii).} Suppose \(\hat y\) minimizes but some \(v \in \col(X)\) has \(v^\top(y - \hat y) \neq 0\); rescale to \(\|v\| = 1\). For \(\tilde y(t) = \hat y + tv \in \col(X)\),
\[
  \|y - \tilde y(t)\|^2 \;=\; \|y - \hat y\|^2 - 2t\,v^\top(y - \hat y) + t^2,
\]
minimized at \(t^\star = v^\top(y - \hat y) \neq 0\) with value \(\|y - \hat y\|^2 - (t^\star)^2 < \|y - \hat y\|^2\), contradicting (i).

\textbf{Closed form.} Writing \(\hat y = X\hat\beta\), condition (iii) becomes \(X^\top X \hat\beta = X^\top y\), the normal equation of \S\ref{sec:2.1.3}. Under \Aref{2}, \(\hat\beta = (X^\top X)^{-1} X^\top y\), and since the orthogonal projection onto a closed subspace is unique, so is \(\hat y\).
\end{proof}

