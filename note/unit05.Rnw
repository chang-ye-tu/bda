    }
    % Right Child (f1 = 1)
    child {
        node[leaf_pos] {Label = 1 \\[-0.5ex] {\small (Catches $a_{u_1}, a_{u_2}$)}}
        edge from parent node[edge_label, right=2pt] {$f_1 = 1$}
    };

\end{tikzpicture}
\caption{Comb tree for the cover $\{S_1, S_2\}$ in Example~\ref{ex:setcover-reduction}.}\label{fig:setcover-comb}
\end{figure}

\begin{example}[Reverse direction in action]\label{ex:reverse-extraction}
Take $U = \{u_1, u_2, u_3, u_4\}$ and $\mathcal{S} = \{S_1, S_2, S_3, S_4\}$ with $S_1 = \{u_1, u_2\}$, $S_2 = \{u_3, u_4\}$, $S_3 = \{u_1, u_3\}$, $S_4 = \{u_2, u_4\}$. The minimum cover has $k = 2$. The reduction sets $K = 3$ and produces
\[
  a_{u_1} = (1, 0, 1, 0), \;\; a_{u_2} = (1, 0, 0, 1), \;\; a_{u_3} = (0, 1, 1, 0), \;\; a_{u_4} = (0, 1, 0, 1), \;\; b = (0, 0, 0, 0).
\]
The non-comb 4-leaf tree of Figure~\ref{fig:reverse-tree} classifies all five rows correctly. Tracing $b$: $b_{f_1} = 0$ goes left at the root, $b_{f_2} = 0$ goes left at the next test, lands at the negative leaf. The features along the path give $\mathcal{S}' = \{S_1, S_2\}$, an optimal cover of size 2.

The bound $|T| \geqslant t + 1$ is loose here ($4 \geqslant 3$): the right subtree of the root holds two leaves not on $b$'s path. A comb tree producing the same cover would have $|T| = t + 1 = 3$ leaves.
\end{example}

