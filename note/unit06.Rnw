\begin{motivation}[From hyperplanes to margins]
Logistic regression in Unit~3 placed a hyperplane to maximize the data likelihood. The support vector machine places a hyperplane to maximize the geometric distance from the closest training point. The two criteria differ; the second one delivers a constrained convex problem whose dual exposes which training points actually shape the decision boundary, and turns the inner product $\mathbf{x}_i^\top \mathbf{x}_j$ into a slot a kernel can occupy.
\end{motivation}

\section{Constrained Convex Optimization}\label{sec:6.1}

The convex analysis chapter of Unit~1 (\S 1.9) treated unconstrained minimization: gradient zero, Hessian PSD, done. The SVM problems in this unit are constrained: minimize a convex objective subject to one inequality per training point. Three additions to the Unit~1 toolkit handle the constrained case: the Lagrangian, weak and strong duality, and the KKT conditions.

\subsection{Constrained problems in standard form}\label{subsec:6.1.1}

\begin{definition}[Constrained optimization problem]\label{def:constr-prob}
A \textbf{constrained optimization problem} in standard form is
\[
\begin{aligned}
\min_{\mathbf{x} \in \mathbb{R}^n} \;& f_0(\mathbf{x}) \\
\text{subject to } & f_i(\mathbf{x}) \leqslant 0, \quad i = 1, \ldots, m, \\
                   & h_j(\mathbf{x}) = 0, \quad j = 1, \ldots, p.
\end{aligned}
\]
The function $f_0$ is the \textbf{objective}; $f_1, \ldots, f_m$ are the \textbf{inequality constraint functions}; $h_1, \ldots, h_p$ are the \textbf{equality constraint functions}. The \textbf{feasible set} is
\[
\mathcal{D} \;=\; \big\{\mathbf{x} \in \mathbb{R}^n : f_i(\mathbf{x}) \leqslant 0 \text{ for all } i,\; h_j(\mathbf{x}) = 0 \text{ for all } j\big\}.
\]
The \textbf{optimal value} is $p^\star = \inf\{f_0(\mathbf{x}) : \mathbf{x} \in \mathcal{D}\}$, with the conventions $p^\star = +\infty$ when $\mathcal{D} = \varnothing$ (the problem is \textbf{infeasible}) and $p^\star = -\infty$ when $f_0$ is unbounded below on $\mathcal{D}$. A point $\mathbf{x}^\star \in \mathcal{D}$ achieving $f_0(\mathbf{x}^\star) = p^\star$ is an \textbf{optimal point}.
\end{definition}

The problem is a \textbf{convex optimization problem} when $f_0, f_1, \ldots, f_m$ are convex on $\mathbb{R}^n$ and each $h_j$ is affine, $h_j(\mathbf{x}) = \mathbf{a}_j^\top \mathbf{x} - b_j$. Affine equalities define a translated subspace; convex sublevel sets $\{f_i \leqslant 0\}$ are convex (Unit~1 \S 1.9.8, epigraph characterization); their intersection $\mathcal{D}$ is therefore convex. Both Unit~1's unconstrained problems ($m = p = 0$) and the SVM formulations developed below fit this template.

\begin{definition}[Slater's condition]\label{def:slater}
A convex problem in the form of Definition~\ref{def:constr-prob} satisfies \textbf{Slater's condition} if there exists $\tilde{\mathbf{x}} \in \mathcal{D}$ with
\[
f_i(\tilde{\mathbf{x}}) < 0, \qquad i = 1, \ldots, m,
\]
i.e., a feasible point at which every nonlinear inequality constraint holds strictly. When some $f_i$ is itself affine, the strict inequality is relaxed to $f_i(\tilde{\mathbf{x}}) \leqslant 0$ at $\tilde{\mathbf{x}}$ for those affine constraints; strict feasibility is required only for the genuinely nonlinear convex inequalities.
\end{definition}

Slater's condition is the standard \textbf{constraint qualification} for convex problems. It rules out the degenerate case of a convex inequality that is "tight everywhere" on the feasible set, a case in which the primal and dual optimal values (defined below) can differ. For every primal SVM problem written down later in this unit, Slater's condition holds.

\subsection{Lagrangian and dual function}\label{subsec:6.1.2}

The constrained problem of Definition~\ref{def:constr-prob} becomes more tractable after merging the constraints into the objective with one multiplier per constraint.

\begin{definition}[Lagrangian]\label{def:lagrangian}
The \textbf{Lagrangian} associated with the constrained problem of Definition~\ref{def:constr-prob} is the function $L : \mathbb{R}^n \times \mathbb{R}^m \times \mathbb{R}^p \to \mathbb{R}$,
\[
L(\mathbf{x}, \boldsymbol\lambda, \boldsymbol\nu) \;=\; f_0(\mathbf{x}) \;+\; \sum_{i=1}^{m} \lambda_i\, f_i(\mathbf{x}) \;+\; \sum_{j=1}^{p} \nu_j\, h_j(\mathbf{x}).
\]
The scalars $\lambda_1, \ldots, \lambda_m$ are the \textbf{Lagrange multipliers} for the inequality constraints; $\nu_1, \ldots, \nu_p$ are the multipliers for the equality constraints. The pair $(\boldsymbol\lambda, \boldsymbol\nu)$ is the \textbf{dual variable}.
\end{definition}

\begin{definition}[Dual function]\label{def:dual-fn}
The \textbf{Lagrange dual function} is $g : \mathbb{R}^m \times \mathbb{R}^p \to [-\infty, +\infty)$,
\[
g(\boldsymbol\lambda, \boldsymbol\nu) \;=\; \inf_{\mathbf{x} \in \mathbb{R}^n}\, L(\mathbf{x}, \boldsymbol\lambda, \boldsymbol\nu).
\]
Its \textbf{effective domain} is $\dom g = \{(\boldsymbol\lambda, \boldsymbol\nu) : g(\boldsymbol\lambda, \boldsymbol\nu) > -\infty\}$.
\end{definition}

The infimum runs over all of $\mathbb{R}^n$, not over the feasible set $\mathcal{D}$: the dual function relaxes the original constraints and lets any violation be paid for through the multipliers.

\begin{theorem}[Concavity of the dual function]\label{thm:dual-concave}
The dual function $g$ is concave on $\mathbb{R}^m \times \mathbb{R}^p$, regardless of whether the primal problem is convex.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:dual-concave}]
For each fixed $\mathbf{x}$, the map $(\boldsymbol\lambda, \boldsymbol\nu) \mapsto L(\mathbf{x}, \boldsymbol\lambda, \boldsymbol\nu) = f_0(\mathbf{x}) + \sum_i \lambda_i f_i(\mathbf{x}) + \sum_j \nu_j h_j(\mathbf{x})$ is affine in $(\boldsymbol\lambda, \boldsymbol\nu)$. The dual function $g$ is the pointwise infimum of this family of affine functions indexed by $\mathbf{x} \in \mathbb{R}^n$. Equivalently, $-g$ is the pointwise supremum of a family of affine functions, which is convex (Unit~1 \S 1.9.7, pointwise supremum); hence $g$ is concave. $\blacksquare$
\end{derivation}

Concavity of $g$ does not require the primal to be convex. The next subsection turns this concave function into a problem whose value lower-bounds $p^\star$.

\subsection{Weak duality}\label{subsec:6.1.3}

The dual function $g$ is concave (Theorem~\ref{thm:dual-concave}), so maximizing it is a concave problem. The inequality multipliers $\boldsymbol\lambda$ are constrained to be nonnegative; the equality multipliers $\boldsymbol\nu$ are unrestricted.

\begin{definition}[Dual problem]\label{def:dual-prob}
The \textbf{Lagrange dual problem} associated with the primal problem of Definition~\ref{def:constr-prob} is
\[
\sup_{\boldsymbol\lambda \in \mathbb{R}^m,\, \boldsymbol\nu \in \mathbb{R}^p}\, g(\boldsymbol\lambda, \boldsymbol\nu) \quad \text{subject to } \boldsymbol\lambda \geqslant \mathbf{0}.
\]
Its \textbf{optimal value} is $d^\star = \sup\{g(\boldsymbol\lambda, \boldsymbol\nu) : \boldsymbol\lambda \geqslant \mathbf{0}\}$, with $d^\star = -\infty$ when the feasible set $\{\boldsymbol\lambda \geqslant \mathbf{0}\} \cap \dom g$ is empty and $d^\star = +\infty$ when $g$ is unbounded above on this set. A pair $(\boldsymbol\lambda^\star, \boldsymbol\nu^\star)$ achieving the supremum is \textbf{dual optimal}.
\end{definition}

\begin{theorem}[Weak duality]\label{thm:weak-duality}
For every primal problem in the form of Definition~\ref{def:constr-prob}, convex or not,
\[
d^\star \;\leqslant\; p^\star.
\]
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:weak-duality}]
Let $\mathbf{x} \in \mathcal{D}$ be primal feasible, so $f_i(\mathbf{x}) \leqslant 0$ for all $i$ and $h_j(\mathbf{x}) = 0$ for all $j$. For any $\boldsymbol\lambda \geqslant \mathbf{0}$ and $\boldsymbol\nu \in \mathbb{R}^p$,
\[
\sum_{i} \lambda_i f_i(\mathbf{x}) \;\leqslant\; 0, \qquad \sum_{j} \nu_j h_j(\mathbf{x}) \;=\; 0,
\]
the first because each $\lambda_i \geqslant 0$ multiplies a nonpositive number, the second because each $h_j(\mathbf{x}) = 0$. Therefore
\[
L(\mathbf{x}, \boldsymbol\lambda, \boldsymbol\nu) \;=\; f_0(\mathbf{x}) + \sum_i \lambda_i f_i(\mathbf{x}) + \sum_j \nu_j h_j(\mathbf{x}) \;\leqslant\; f_0(\mathbf{x}).
\]
The dual function value is the infimum of the Lagrangian over all $\mathbf{z} \in \mathbb{R}^n$, hence is at most its value at the specific point $\mathbf{x}$:
\[
g(\boldsymbol\lambda, \boldsymbol\nu) \;=\; \inf_{\mathbf{z} \in \mathbb{R}^n} L(\mathbf{z}, \boldsymbol\lambda, \boldsymbol\nu) \;\leqslant\; L(\mathbf{x}, \boldsymbol\lambda, \boldsymbol\nu) \;\leqslant\; f_0(\mathbf{x}).
\]
This holds for every $\mathbf{x} \in \mathcal{D}$, so taking the infimum over $\mathcal{D}$ on the right,
\[
g(\boldsymbol\lambda, \boldsymbol\nu) \;\leqslant\; \inf_{\mathbf{x} \in \mathcal{D}} f_0(\mathbf{x}) \;=\; p^\star.
\]
The bound holds for every $(\boldsymbol\lambda, \boldsymbol\nu)$ with $\boldsymbol\lambda \geqslant \mathbf{0}$; taking the supremum over those pairs gives
$d^\star = \sup_{\boldsymbol\lambda \geqslant 0,\, \boldsymbol\nu} g(\boldsymbol\lambda, \boldsymbol\nu) \leqslant p^\star$. $\blacksquare$
\end{derivation}

\begin{definition}[Duality gap]\label{def:duality-gap}
The \textbf{duality gap} is the nonnegative number $p^\star - d^\star$. The gap is \textbf{closed} (and \textbf{strong duality} is said to hold) when $p^\star = d^\star$; otherwise the gap is open, and $d^\star$ is only a lower bound on $p^\star$.
\end{definition}

Weak duality is unconditional: it holds whether or not the primal is convex, whether or not Slater's condition is satisfied, and whether or not the primal or dual optima are attained. For a difficult primal, the dual still produces a usable lower bound on $p^\star$. The next subsection identifies the conditions under which the bound is tight.

\subsection{Strong duality under Slater's condition}\label{subsec:6.1.4}

Slater's condition combined with primal convexity closes the duality gap. The proof needs one more piece of separation theory than Unit~1 supplied: a lemma on disjoint convex sets, derived from Unit~1's projection and supporting-hyperplane theorems.

\begin{lemma}[Hyperplane separation of disjoint convex sets]\label{lem:sep-hyperplane}
Let $A, B \subseteq \mathbb{R}^N$ be non-empty disjoint convex sets. There exists a non-zero vector $\mathbf{a} \in \mathbb{R}^N$ such that
\[
\sup_{\mathbf{y} \in B} \mathbf{a}^\top \mathbf{y} \;\leqslant\; \inf_{\mathbf{x} \in A} \mathbf{a}^\top \mathbf{x}.
\]
\end{lemma}

\begin{derivation}[Proof of Lemma~\ref{lem:sep-hyperplane}]
Let $C = \{\mathbf{x} - \mathbf{y} : \mathbf{x} \in A,\, \mathbf{y} \in B\}$. The set $C$ is convex: if $\mathbf{x}_k - \mathbf{y}_k \in C$ for $k = 1, 2$, then for $\theta \in [0, 1]$,
\[
\theta(\mathbf{x}_1 - \mathbf{y}_1) + (1-\theta)(\mathbf{x}_2 - \mathbf{y}_2) \;=\; \big[\theta \mathbf{x}_1 + (1-\theta)\mathbf{x}_2\big] \;-\; \big[\theta \mathbf{y}_1 + (1-\theta)\mathbf{y}_2\big] \;\in\; C
\]
by convexity of $A$ and $B$. Disjointness $A \cap B = \varnothing$ gives $\mathbf{0} \notin C$. Two cases on the position of $\mathbf{0}$ relative to $\overline{C}$, the closure of $C$.

\textbf{Case 1: $\mathbf{0} \notin \overline{C}$.} The closed convex set $\overline{C}$ admits a unique closest point $\mathbf{z}^\star$ to $\mathbf{0}$ with $\|\mathbf{z}^\star\| > 0$ (Unit~1 \S 1.9.8, projection step). The variational inequality $(\mathbf{0} - \mathbf{z}^\star)^\top (\mathbf{z} - \mathbf{z}^\star) \leqslant 0$ for $\mathbf{z} \in \overline{C}$ rearranges to $(\mathbf{z}^\star)^\top \mathbf{z} \geqslant \|\mathbf{z}^\star\|^2 > 0$. Setting $\mathbf{a} = \mathbf{z}^\star$ gives $\mathbf{a}^\top (\mathbf{x} - \mathbf{y}) \geqslant \|\mathbf{a}\|^2 > 0$ for every $\mathbf{x} \in A$, $\mathbf{y} \in B$.

\textbf{Case 2: $\mathbf{0} \in \overline{C}$.} Since $\mathbf{0} \notin C$, the origin is a boundary point of $\overline{C}$. By the supporting hyperplane theorem (Unit~1 \S 1.9.8), there exists $\mathbf{b} \neq \mathbf{0}$ with $\mathbf{b}^\top \mathbf{z} \leqslant \mathbf{b}^\top \mathbf{0} = 0$ for every $\mathbf{z} \in \overline{C}$. Setting $\mathbf{a} = -\mathbf{b}$, $\mathbf{a}^\top (\mathbf{x} - \mathbf{y}) \geqslant 0$ for every $\mathbf{x} \in A$, $\mathbf{y} \in B$.

In both cases, $\mathbf{a}^\top \mathbf{x} \geqslant \mathbf{a}^\top \mathbf{y}$ for $\mathbf{x} \in A$, $\mathbf{y} \in B$, which gives the stated supremum-infimum inequality. $\blacksquare$
\end{derivation}

\begin{theorem}[Strong duality under Slater]\label{thm:strong-duality}
Suppose the primal problem of Definition~\ref{def:constr-prob} has only inequality constraints (no equality constraints, $p = 0$), is convex (each $f_i$ convex on $\mathbb{R}^n$), has finite optimal value $p^\star \in \mathbb{R}$, and satisfies Slater's condition. Then $d^\star = p^\star$, and the dual optimum is attained: there exists $\boldsymbol\lambda^\star \geqslant \mathbf{0}$ with $g(\boldsymbol\lambda^\star) = d^\star = p^\star$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:strong-duality}]
\textbf{Step 1: Value set $A$ is convex.} Define
\[
A \;=\; \big\{(\mathbf{u}, t) \in \mathbb{R}^m \times \mathbb{R} : \exists\, \mathbf{x} \in \mathbb{R}^n \text{ with } f_i(\mathbf{x}) \leqslant u_i \text{ for } i = 1, \ldots, m,\; f_0(\mathbf{x}) \leqslant t\big\}.
\]
Take $(\mathbf{u}, t), (\mathbf{u}', t') \in A$ with witnesses $\mathbf{x}, \mathbf{x}'$. For $\theta \in [0, 1]$, set $\mathbf{z} = \theta \mathbf{x} + (1-\theta)\mathbf{x}'$. Convexity of $f_i$ and $f_0$ gives
\[
f_i(\mathbf{z}) \leqslant \theta f_i(\mathbf{x}) + (1-\theta) f_i(\mathbf{x}') \leqslant \theta u_i + (1-\theta) u_i', \quad
f_0(\mathbf{z}) \leqslant \theta t + (1-\theta) t',
\]
so $\theta(\mathbf{u}, t) + (1-\theta)(\mathbf{u}', t') \in A$ with witness $\mathbf{z}$.

\textbf{Step 2: $p^\star = \inf\{t : (\mathbf{0}, t) \in A\}$.} If $(\mathbf{0}, t) \in A$, the witness $\mathbf{x}$ satisfies $f_i(\mathbf{x}) \leqslant 0$ (so $\mathbf{x}$ is primal feasible) and $f_0(\mathbf{x}) \leqslant t$, hence $p^\star \leqslant t$. Conversely, for any primal feasible $\mathbf{x}$, $(\mathbf{0}, f_0(\mathbf{x})) \in A$, so $\inf\{t : (\mathbf{0}, t) \in A\} \leqslant p^\star$.

\textbf{Step 3: Separate $A$ from a half-line.} Let $B = \{(\mathbf{0}, s) : s < p^\star\} \subseteq \mathbb{R}^m \times \mathbb{R}$, convex. Step~2 gives $A \cap B = \varnothing$. Lemma~\ref{lem:sep-hyperplane} produces $(\boldsymbol\mu, \mu_0) \neq (\mathbf{0}, 0)$ with
\[
\boldsymbol\mu^\top \mathbf{u} + \mu_0 t \;\geqslant\; \mu_0 s \qquad \text{for every } (\mathbf{u}, t) \in A,\; s < p^\star.
\]
Fix $(\mathbf{u}, t) \in A$. As $s \to -\infty$ on the right, the LHS is constant; if $\mu_0 < 0$ then $\mu_0 s \to +\infty$ and the inequality fails. So $\mu_0 \geqslant 0$. With $\mu_0 \geqslant 0$, $\sup_{s < p^\star} \mu_0 s = \mu_0 p^\star$, giving
\[
\boldsymbol\mu^\top \mathbf{u} + \mu_0 t \;\geqslant\; \mu_0 p^\star \qquad \text{for every } (\mathbf{u}, t) \in A. \tag{$\star$}
\]

\textbf{Step 4: $\boldsymbol\mu \geqslant \mathbf{0}$.} For any $(\mathbf{u}, t) \in A$ and $\delta > 0$, the point $(\mathbf{u} + \delta \mathbf{e}_i, t)$ is also in $A$ (the same witness $\mathbf{x}$ has $f_i(\mathbf{x}) \leqslant u_i \leqslant u_i + \delta$). Apply $(\star)$ at the perturbed point:
\[
\boldsymbol\mu^\top \mathbf{u} + \delta \mu_i + \mu_0 t \;\geqslant\; \mu_0 p^\star.
\]
For this to hold for every $\delta > 0$ with the LHS otherwise fixed, $\mu_i \geqslant 0$ (else $\delta \to \infty$ drives the LHS to $-\infty$). Repeat for each $i$.

\textbf{Step 5: $\mu_0 > 0$.} Suppose $\mu_0 = 0$. Slater's condition supplies $\tilde{\mathbf{x}}$ with $f_i(\tilde{\mathbf{x}}) < 0$ for $i = 1, \ldots, m$, and the point $(f_1(\tilde{\mathbf{x}}), \ldots, f_m(\tilde{\mathbf{x}}), f_0(\tilde{\mathbf{x}})) \in A$ (witness $\tilde{\mathbf{x}}$). Apply $(\star)$ with $\mu_0 = 0$:
\[
\sum_{i=1}^m \mu_i\, f_i(\tilde{\mathbf{x}}) \;\geqslant\; 0.
\]
Each summand $\mu_i f_i(\tilde{\mathbf{x}}) \leqslant 0$ (Step~4 gives $\mu_i \geqslant 0$, Slater gives $f_i(\tilde{\mathbf{x}}) < 0$), so the sum is $\leqslant 0$. Combined: the sum equals $0$, hence each summand is $0$, hence $\mu_i = 0$ (since $f_i(\tilde{\mathbf{x}}) \neq 0$). Thus $(\boldsymbol\mu, \mu_0) = (\mathbf{0}, 0)$, contradicting Lemma~\ref{lem:sep-hyperplane}. So $\mu_0 > 0$.

\textbf{Step 6: Identify the multiplier.} Set $\boldsymbol\lambda^\star = \boldsymbol\mu / \mu_0 \in \mathbb{R}^m_{\geqslant 0}$. For every $\mathbf{x} \in \mathbb{R}^n$, the point $(f_1(\mathbf{x}), \ldots, f_m(\mathbf{x}), f_0(\mathbf{x})) \in A$ (witness $\mathbf{x}$). Substituting into $(\star)$ and dividing by $\mu_0 > 0$:
\[
\sum_{i=1}^m \lambda_i^\star f_i(\mathbf{x}) + f_0(\mathbf{x}) \;\geqslant\; p^\star, \qquad \text{i.e., } L(\mathbf{x}, \boldsymbol\lambda^\star) \geqslant p^\star \;\forall \mathbf{x} \in \mathbb{R}^n.
\]
Taking the infimum over $\mathbf{x}$: $g(\boldsymbol\lambda^\star) \geqslant p^\star$.

\textbf{Step 7: Combine with weak duality.} Weak duality (Theorem~\ref{thm:weak-duality}) gives $d^\star \leqslant p^\star$. Step~6 gives $g(\boldsymbol\lambda^\star) \geqslant p^\star$, and $\boldsymbol\lambda^\star \geqslant \mathbf{0}$ makes $g(\boldsymbol\lambda^\star)$ a candidate for the dual supremum, so $g(\boldsymbol\lambda^\star) \leqslant d^\star$. Stacking the chain:
\[
p^\star \;\leqslant\; g(\boldsymbol\lambda^\star) \;\leqslant\; d^\star \;\leqslant\; p^\star.
\]
All inequalities are equalities; $g(\boldsymbol\lambda^\star) = d^\star = p^\star$, so $\boldsymbol\lambda^\star$ attains the dual optimum. $\blacksquare$
\end{derivation}

\begin{suppremark}[Affine equality constraints]
The same argument extends to convex problems with affine equality constraints $\mathbf{A}\mathbf{x} = \mathbf{b}$, with Slater's condition strengthened to require strict feasibility for nonlinear inequality constraints only (affine constraints are required to be feasible, not strictly so). Hard-margin and soft-margin SVM use only inequality constraints, so Theorem~\ref{thm:strong-duality} applies directly without invoking the equality extension.
\end{suppremark}

Strong duality is the foundation of the SVM dual: applied to the SVM primal, Theorem~\ref{thm:strong-duality} guarantees that solving the dual recovers the primal optimum. The corresponding multipliers satisfy a system of equalities and complementary-slackness conditions developed next.

\subsection{KKT conditions}\label{subsec:6.1.5}

The KKT (Karush-Kuhn-Tucker) conditions are the first-order optimality conditions for constrained convex problems. Under the hypotheses of Theorem~\ref{thm:strong-duality} together with differentiability, they characterize primal-dual optimal pairs.

\begin{definition}[KKT conditions]\label{def:kkt}
For the convex inequality-constrained problem of Definition~\ref{def:constr-prob} (no equality constraints) with $f_0, f_1, \ldots, f_m$ differentiable, the \textbf{Karush-Kuhn-Tucker (KKT) conditions} at a pair $(\mathbf{x}^\star, \boldsymbol\lambda^\star) \in \mathbb{R}^n \times \mathbb{R}^m$ are
\begin{enumerate}[label=\textup{(\roman*)},ref=\textup{(\roman*)},leftmargin=2em,itemsep=2pt,topsep=2pt]
\item\label{kkt:stat} \textbf{Stationarity}: $\displaystyle \nabla f_0(\mathbf{x}^\star) + \sum_{i=1}^{m} \lambda_i^\star\, \nabla f_i(\mathbf{x}^\star) \;=\; \mathbf{0}$;
\item\label{kkt:pfeas} \textbf{Primal feasibility}: $f_i(\mathbf{x}^\star) \leqslant 0$ for $i = 1, \ldots, m$;
\item\label{kkt:dfeas} \textbf{Dual feasibility}: $\lambda_i^\star \geqslant 0$ for $i = 1, \ldots, m$;
\item\label{kkt:cs} \textbf{Complementary slackness}: $\lambda_i^\star\, f_i(\mathbf{x}^\star) = 0$ for $i = 1, \ldots, m$.
\end{enumerate}
\end{definition}

Each condition has a substantive reading:
\begin{itemize}[label={},leftmargin=2em,itemsep=4pt,topsep=2pt]
\item \ref{kkt:stat} extends the unconstrained first-order condition $\nabla f_0(\mathbf{x}^\star) = \mathbf{0}$ (Unit~1 \S 1.9.5). At a constrained optimum, $\mathbf{x}^\star$ globally minimizes the Lagrangian $L(\cdot, \boldsymbol\lambda^\star)$ over $\mathbb{R}^n$, and convexity plus differentiability force $\nabla_{\mathbf{x}} L(\mathbf{x}^\star, \boldsymbol\lambda^\star) = \mathbf{0}$. The proof of \autoref{thm:kkt-necessary} below derives this from strong duality.
\item \ref{kkt:pfeas} restates that $\mathbf{x}^\star$ is feasible.
\item \ref{kkt:dfeas} comes from weak duality (\S\ref{subsec:6.1.3}): if some $\lambda_i < 0$, then $\lambda_i f_i(\mathbf{x})$ in the Lagrangian rewards $f_i(\mathbf{x}) > 0$ rather than penalizes it, sending $\inf_{\mathbf{x}} L(\mathbf{x}, \boldsymbol\lambda) \to -\infty$. Only $\boldsymbol\lambda \geqslant \mathbf{0}$ keeps $g(\boldsymbol\lambda)$ a finite lower bound on $p^\star$.
\item \ref{kkt:cs} encodes the equality $g(\boldsymbol\lambda^\star) = f_0(\mathbf{x}^\star)$ from strong duality. Expanding $g(\boldsymbol\lambda^\star) = \inf_{\mathbf{x}} L(\mathbf{x}, \boldsymbol\lambda^\star) \leqslant L(\mathbf{x}^\star, \boldsymbol\lambda^\star) = f_0(\mathbf{x}^\star) + \sum_i \lambda_i^\star f_i(\mathbf{x}^\star)$ forces $\sum_i \lambda_i^\star f_i(\mathbf{x}^\star) \geqslant 0$; each summand is $\leqslant 0$ by \ref{kkt:dfeas}, \ref{kkt:pfeas}, so all summands vanish, giving $\lambda_i^\star f_i(\mathbf{x}^\star) = 0$ termwise.
\end{itemize}

\begin{theorem}[KKT, necessary]\label{thm:kkt-necessary}
Assume the primal problem of Definition~\ref{def:constr-prob} is convex with $f_0, f_i$ differentiable on $\mathbb{R}^n$ for $i = 0, 1, \ldots, m$, has no equality constraints and finite optimal value $p^\star$, and satisfies Slater's condition. If $\mathbf{x}^\star$ is primal optimal and $\boldsymbol\lambda^\star$ is dual optimal, then the KKT conditions of Definition~\ref{def:kkt} hold at $(\mathbf{x}^\star, \boldsymbol\lambda^\star)$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:kkt-necessary}]
Primal feasibility \ref{kkt:pfeas} and dual feasibility \ref{kkt:dfeas} hold by hypothesis. By strong duality (Theorem~\ref{thm:strong-duality}), $g(\boldsymbol\lambda^\star) = d^\star = p^\star = f_0(\mathbf{x}^\star)$. Expanding the dual function:
\[
f_0(\mathbf{x}^\star) \;=\; g(\boldsymbol\lambda^\star) \;=\; \inf_{\mathbf{x} \in \mathbb{R}^n} L(\mathbf{x}, \boldsymbol\lambda^\star) \;\leqslant\; L(\mathbf{x}^\star, \boldsymbol\lambda^\star) \;=\; f_0(\mathbf{x}^\star) + \sum_{i=1}^{m} \lambda_i^\star\, f_i(\mathbf{x}^\star).
\]
Subtracting $f_0(\mathbf{x}^\star)$ gives $\sum_i \lambda_i^\star f_i(\mathbf{x}^\star) \geqslant 0$. Each summand is $\leqslant 0$ by \ref{kkt:pfeas} and \ref{kkt:dfeas}; the sum is therefore $\leqslant 0$ as well. Both bounds together force every summand to be $0$, which is complementary slackness \ref{kkt:cs}.

With $\sum_i \lambda_i^\star f_i(\mathbf{x}^\star) = 0$, the displayed inequality is an equality: $L(\mathbf{x}^\star, \boldsymbol\lambda^\star) = \inf_{\mathbf{x}} L(\mathbf{x}, \boldsymbol\lambda^\star)$. So $\mathbf{x}^\star$ globally minimizes $L(\cdot, \boldsymbol\lambda^\star)$ on $\mathbb{R}^n$. The function $L(\cdot, \boldsymbol\lambda^\star) = f_0 + \sum_i \lambda_i^\star f_i$ is convex (nonnegative combination of convex functions; Unit~1 \S 1.9.7) and differentiable, so the first-order optimality corollary (Unit~1 \S 1.9.5) gives $\nabla_{\mathbf{x}} L(\mathbf{x}^\star, \boldsymbol\lambda^\star) = \mathbf{0}$, which is stationarity \ref{kkt:stat}. $\blacksquare$
\end{derivation}

\begin{theorem}[KKT, sufficient]\label{thm:kkt-sufficient}
Assume the primal problem of Definition~\ref{def:constr-prob} is convex with $f_0, f_i$ differentiable on $\mathbb{R}^n$, and has no equality constraints. If the KKT conditions hold at $(\mathbf{x}^\star, \boldsymbol\lambda^\star)$, then $\mathbf{x}^\star$ is primal optimal, $\boldsymbol\lambda^\star$ is dual optimal, and $p^\star = d^\star$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:kkt-sufficient}]
By \ref{kkt:dfeas}, $L(\cdot, \boldsymbol\lambda^\star) = f_0 + \sum_i \lambda_i^\star f_i$ is a nonnegative combination of convex differentiable functions, hence convex and differentiable. Stationarity \ref{kkt:stat} is $\nabla_{\mathbf{x}} L(\mathbf{x}^\star, \boldsymbol\lambda^\star) = \mathbf{0}$, so by Unit~1's first-order optimality corollary (\S 1.9.5), $\mathbf{x}^\star$ globally minimizes $L(\cdot, \boldsymbol\lambda^\star)$:
\[
g(\boldsymbol\lambda^\star) \;=\; L(\mathbf{x}^\star, \boldsymbol\lambda^\star) \;=\; f_0(\mathbf{x}^\star) + \sum_i \lambda_i^\star f_i(\mathbf{x}^\star) \;=\; f_0(\mathbf{x}^\star),
\]
the last equality by complementary slackness \ref{kkt:cs}. For any primal feasible $\mathbf{x}$,
\[
f_0(\mathbf{x}) \;\geqslant\; f_0(\mathbf{x}) + \sum_i \lambda_i^\star f_i(\mathbf{x}) \;=\; L(\mathbf{x}, \boldsymbol\lambda^\star) \;\geqslant\; L(\mathbf{x}^\star, \boldsymbol\lambda^\star) \;=\; f_0(\mathbf{x}^\star),
\]
where the first inequality uses $\lambda_i^\star \geqslant 0$ and $f_i(\mathbf{x}) \leqslant 0$ (primal feasibility of $\mathbf{x}$), and the second inequality is the global-minimum property of $\mathbf{x}^\star$ for $L(\cdot, \boldsymbol\lambda^\star)$. Hence $f_0(\mathbf{x}^\star) \leqslant f_0(\mathbf{x})$ for every primal feasible $\mathbf{x}$, so $\mathbf{x}^\star$ is primal optimal and $f_0(\mathbf{x}^\star) = p^\star$. Weak duality gives $g(\boldsymbol\lambda^\star) \leqslant d^\star \leqslant p^\star$; combined with $g(\boldsymbol\lambda^\star) = f_0(\mathbf{x}^\star) = p^\star$, all three are equal, so $\boldsymbol\lambda^\star$ is dual optimal and the duality gap closes. $\blacksquare$
\end{derivation}

\begin{suppremark}[Non-differentiable case]
When $f_0$ or some $f_i$ is convex but not differentiable, stationarity \ref{kkt:stat} is replaced by the subgradient inclusion $\mathbf{0} \in \partial_{\mathbf{x}} L(\mathbf{x}^\star, \boldsymbol\lambda^\star)$, where $\partial_{\mathbf{x}}$ is the subdifferential in $\mathbf{x}$ (Unit~1 \S 1.9.5). Conditions \ref{kkt:pfeas}--\ref{kkt:cs} are unchanged. Unit~2 \S 2.3.2 used the subgradient form for Lasso: the unconstrained Lasso problem has a subgradient stationarity condition that yields the soft-thresholding update.
\end{suppremark}

The hard-margin and soft-margin SVM problems both satisfy the hypotheses of Theorems~\ref{thm:kkt-necessary} and \ref{thm:kkt-sufficient}: convex objective, differentiable, only inequality constraints, and Slater's condition holds (under separability for hard margin, or for any $C > 0$ in soft margin). The next sections derive the SVM dual and read the support-vector geometry directly off the KKT conditions.

\section{Maximum-Margin Classifier}\label{sec:6.2}

The hard-margin support vector machine fits a separating hyperplane to linearly separable data by maximizing the geometric distance from the closest training point.

\subsection{Functional and geometric margins}\label{subsec:6.2.1}

Throughout this section, the training data are $\{(\mathbf{x}_i, y_i)\}_{i=1}^{n}$ with $\mathbf{x}_i \in \mathbb{R}^p$ and $y_i \in \{-1, +1\}$. A \textbf{linear classifier} $(\mathbf{w}, b) \in \mathbb{R}^p \times \mathbb{R}$ predicts $\operatorname{sign}(\mathbf{w}^\top \mathbf{x} + b)$. Its \textbf{decision boundary} is the hyperplane
\[
H(\mathbf{w}, b) \;=\; \{\mathbf{x} \in \mathbb{R}^p : \mathbf{w}^\top \mathbf{x} + b = 0\}.
\]

\begin{definition}[Linear separability]\label{def:linsep}
The training data $\{(\mathbf{x}_i, y_i)\}_{i=1}^n$ are \textbf{linearly separable} if there exist $\mathbf{w} \in \mathbb{R}^p$ and $b \in \mathbb{R}$ with
\[
y_i (\mathbf{w}^\top \mathbf{x}_i + b) \;>\; 0, \qquad i = 1, \ldots, n.
\]
\end{definition}

Linear separability admits infinitely many separating hyperplanes; the SVM selects one by a margin criterion.

\begin{definition}[Functional and geometric margins]\label{def:margins}
For a linear classifier $(\mathbf{w}, b)$ with $\mathbf{w} \neq \mathbf{0}$ and a labeled point $(\mathbf{x}_i, y_i)$, the \textbf{functional margin} is
\[
\gamma_i(\mathbf{w}, b) \;=\; y_i (\mathbf{w}^\top \mathbf{x}_i + b),
\]
and the \textbf{geometric margin} is
\[
\hat\gamma_i(\mathbf{w}, b) \;=\; \frac{y_i (\mathbf{w}^\top \mathbf{x}_i + b)}{\|\mathbf{w}\|}.
\]
The \textbf{geometric margin of the classifier on the dataset} is $\hat\gamma(\mathbf{w}, b) = \min_{i = 1, \ldots, n} \hat\gamma_i(\mathbf{w}, b)$.
\end{definition}

The geometric margin is the perpendicular distance from a point to the hyperplane $H(\mathbf{w}, b)$, derived as follows. The unit normal to $H(\mathbf{w}, b)$ is $\mathbf{w}/\|\mathbf{w}\|$ (the gradient of $\mathbf{z} \mapsto \mathbf{w}^\top \mathbf{z} + b$, normalized). For $\mathbf{x} \in \mathbb{R}^p$, write the perpendicular foot on $H(\mathbf{w}, b)$ as $\mathbf{x} - t\, \mathbf{w}/\|\mathbf{w}\|$ and impose membership:
\[
\mathbf{w}^\top\!\Big(\mathbf{x} - t\,\frac{\mathbf{w}}{\|\mathbf{w}\|}\Big) + b \;=\; 0 \quad \Longrightarrow \quad t \;=\; \frac{\mathbf{w}^\top \mathbf{x} + b}{\|\mathbf{w}\|}.
\]
The scalar $t$ is the signed perpendicular distance from $\mathbf{x}$ to $H(\mathbf{w}, b)$, positive on the side $\{\mathbf{w}^\top \mathbf{z} + b > 0\}$. Multiplying by $y_i \in \{-1, +1\}$ inserts a sign that is positive when the classifier's prediction $\operatorname{sign}(\mathbf{w}^\top \mathbf{x}_i + b)$ agrees with $y_i$, recovering $\hat\gamma_i = y_i(\mathbf{w}^\top \mathbf{x}_i + b)/\|\mathbf{w}\|$. The classifier separates the training data iff $\hat\gamma(\mathbf{w}, b) > 0$.

\paragraph{Scale invariance.} Replacing $(\mathbf{w}, b)$ by $(c\mathbf{w}, cb)$ for $c > 0$ multiplies the functional margin by $c$ and the norm $\|\mathbf{w}\|$ by $c$, so the geometric margin $\hat\gamma_i$ is unchanged. The hyperplane $H(\mathbf{w}, b)$ is also unchanged. Geometric margin therefore measures a property of the decision boundary itself, independent of the parameter scaling used to represent it.

\paragraph{Maximum-margin objective.} The hard-margin SVM searches for the classifier with the largest geometric margin:
\[
\max_{\mathbf{w} \in \mathbb{R}^p,\, b \in \mathbb{R}}\; \hat\gamma(\mathbf{w}, b).
\]
Use scale invariance to fix the normalization $\min_i y_i(\mathbf{w}^\top \mathbf{x}_i + b) = 1$. Any classifier with positive geometric margin admits a unique positive rescaling that produces this equality; the rescaling does not change $\hat\gamma$. Under this normalization $\hat\gamma = 1 / \|\mathbf{w}\|$, so maximizing $\hat\gamma$ becomes minimizing $\|\mathbf{w}\|$, equivalently minimizing $\tfrac{1}{2}\|\mathbf{w}\|^2$. Replacing the equality $\min_i y_i(\cdot) = 1$ by the inequalities $y_i(\cdot) \geqslant 1$ is without loss: at any optimum at least one constraint is tight, since otherwise a small uniform rescaling $(\mathbf{w}, b) \mapsto (c\mathbf{w}, cb)$ with $c \in (0, 1)$ would decrease $\|\mathbf{w}\|$ without violating feasibility.

\begin{definition}[Hard-margin SVM primal]\label{def:hard-svm}
Given linearly separable training data $\{(\mathbf{x}_i, y_i)\}_{i=1}^n$, the \textbf{hard-margin SVM primal problem} is
\[
\min_{\mathbf{w} \in \mathbb{R}^p,\, b \in \mathbb{R}}\; \tfrac{1}{2}\|\mathbf{w}\|^2 \quad \text{subject to } y_i (\mathbf{w}^\top \mathbf{x}_i + b) \geqslant 1, \quad i = 1, \ldots, n.
\]
\end{definition}

The objective $\tfrac{1}{2}\|\mathbf{w}\|^2$ is a convex quadratic in $\mathbf{w}$ (and constant in $b$). Each constraint $1 - y_i (\mathbf{w}^\top \mathbf{x}_i + b) \leqslant 0$ is affine in $(\mathbf{w}, b)$. The hard-margin SVM is therefore a convex quadratic program with affine inequality constraints, fitting the standard form of Definition~\ref{def:constr-prob} with $f_0(\mathbf{w}, b) = \tfrac{1}{2}\|\mathbf{w}\|^2$ and $f_i(\mathbf{w}, b) = 1 - y_i(\mathbf{w}^\top \mathbf{x}_i + b)$.

\subsection{Existence and uniqueness of the optimal hyperplane}\label{subsec:6.2.2}

\begin{theorem}[Hard-margin solution]\label{thm:hard-svm-exists}
On linearly separable training data containing at least one point of each class, the hard-margin SVM primal of Definition~\ref{def:hard-svm} attains a finite optimal value $p^\star > 0$, the optimizer $\mathbf{w}^\star$ is unique, and the set of optimal intercepts $b^\star$ is a closed bounded interval.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:hard-svm-exists}]
The proof uses three standard analysis facts in $\mathbb{R}^d$: every bounded sequence has a convergent subsequence (Bolzano--Weierstrass); a closed set contains the limits of its convergent sequences; a continuous function preserves limits.

\textbf{Feasibility.} Linear separability supplies $(\mathbf{w}_0, b_0)$ with $y_i(\mathbf{w}_0^\top \mathbf{x}_i + b_0) > 0$ for all $i$. Setting $c = 1 / \min_i y_i(\mathbf{w}_0^\top \mathbf{x}_i + b_0) > 0$ and rescaling to $(c\mathbf{w}_0, cb_0)$ produces a point feasible for Definition~\ref{def:hard-svm}.

\textbf{Existence.} Take a feasible minimizing sequence $\{(\mathbf{w}_k, b_k)\}$, $\tfrac{1}{2}\|\mathbf{w}_k\|^2 \to p^\star$. The norms $\|\mathbf{w}_k\|$ are bounded above. Pick any positive-class point $(\mathbf{x}_+, +1)$ and any negative-class point $(\mathbf{x}_-, -1)$; feasibility gives
\[
b_k \;\geqslant\; 1 - \mathbf{w}_k^\top \mathbf{x}_+, \qquad b_k \;\leqslant\; -1 - \mathbf{w}_k^\top \mathbf{x}_-,
\]
which bounds $\{b_k\}$ above and below. By compactness a subsequence converges to some $(\mathbf{w}^\star, b^\star)$. The feasible set is closed (a finite intersection of closed half-spaces), so $(\mathbf{w}^\star, b^\star)$ is feasible; continuity of $\tfrac{1}{2}\|\cdot\|^2$ gives $\tfrac{1}{2}\|\mathbf{w}^\star\|^2 = p^\star$. The optimal value is positive: $\mathbf{w} = \mathbf{0}$ would require $y_i b \geqslant 1$ for every $i$, impossible with both labels present.

\textbf{Uniqueness of $\mathbf{w}^\star$.} Suppose $(\mathbf{w}_1, b_1)$ and $(\mathbf{w}_2, b_2)$ both attain $p^\star$. The midpoint $\big(\tfrac{1}{2}(\mathbf{w}_1 + \mathbf{w}_2), \tfrac{1}{2}(b_1 + b_2)\big)$ is feasible since the constraints are convex. A direct expansion gives the strict-convexity identity for the squared norm:
\[
\big\|\tfrac{1}{2}(\mathbf{w}_1 + \mathbf{w}_2)\big\|^2 \;=\; \tfrac{1}{2}\|\mathbf{w}_1\|^2 + \tfrac{1}{2}\|\mathbf{w}_2\|^2 - \tfrac{1}{4}\|\mathbf{w}_1 - \mathbf{w}_2\|^2 \;=\; 2p^\star - \tfrac{1}{4}\|\mathbf{w}_1 - \mathbf{w}_2\|^2.
\]
The midpoint's objective is therefore $p^\star - \tfrac{1}{8}\|\mathbf{w}_1 - \mathbf{w}_2\|^2$. Optimality forces this to be $\geqslant p^\star$, so $\|\mathbf{w}_1 - \mathbf{w}_2\|^2 \leqslant 0$, hence $\mathbf{w}_1 = \mathbf{w}_2$.

\textbf{Set of optimal $b^\star$.} The objective is constant in $b$, so every $b$ with $(\mathbf{w}^\star, b)$ feasible is itself optimal. That set is the intersection of the half-lines $b \geqslant 1 - (\mathbf{w}^\star)^\top \mathbf{x}_i$ over $i$ with $y_i = +1$ and $b \leqslant -1 - (\mathbf{w}^\star)^\top \mathbf{x}_i$ over $i$ with $y_i = -1$, a closed interval, bounded by the existence step's argument. $\blacksquare$
\end{derivation}

The optimal $\mathbf{w}^\star$ is the unique normal direction of the maximum-margin hyperplane, and the hyperplane itself is uniquely positioned whenever both classes contribute at least one tight (support-vector) constraint. The parallelogram-law uniqueness step echoes the projection lemma in Unit~1 \S 1.9.8: both rest on strict convexity of the squared Euclidean norm.

\section{The Dual SVM and Support Vectors}\label{sec:6.3}

The hard-margin primal of Definition~\ref{def:hard-svm} has a dual quadratic program in $n$ variables (one multiplier per training point), and the KKT conditions identify a small subset of training points as the support vectors that determine the decision boundary.

\subsection{Lagrangian and dual derivation}\label{subsec:6.3.1}

Apply Definition~\ref{def:lagrangian} to the hard-margin primal. The constraints $f_i(\mathbf{w}, b) = 1 - y_i(\mathbf{w}^\top \mathbf{x}_i + b) \leqslant 0$ carry multipliers $\lambda_i \geqslant 0$, and the Lagrangian is
\[
L(\mathbf{w}, b, \boldsymbol\lambda) \;=\; \tfrac{1}{2}\|\mathbf{w}\|^2 + \sum_{i=1}^n \lambda_i \big[1 - y_i(\mathbf{w}^\top \mathbf{x}_i + b)\big] \;=\; \tfrac{1}{2}\|\mathbf{w}\|^2 \;-\; \mathbf{w}^\top \!\sum_{i=1}^n \lambda_i y_i \mathbf{x}_i \;-\; b \sum_{i=1}^n \lambda_i y_i \;+\; \sum_{i=1}^n \lambda_i.
\]

The hard-margin primal is convex with affine inequality constraints; Slater's condition reduces to feasibility (Definition~\ref{def:slater}), ensured by linear separability. By Theorem~\ref{thm:strong-duality}, strong duality holds and a dual optimum is attained. By Theorem~\ref{thm:kkt-necessary}, condition \ref{kkt:stat} of Definition~\ref{def:kkt} (stationarity) holds at the primal-dual optimum:
\[
\nabla_{\mathbf{w}} L \;=\; \mathbf{w}^\star - \sum_{i=1}^n \lambda_i^\star y_i \mathbf{x}_i \;=\; \mathbf{0}, \qquad \frac{\partial L}{\partial b} \;=\; -\sum_{i=1}^n \lambda_i^\star y_i \;=\; 0.
\]
The first equation expresses $\mathbf{w}^\star$ as a linear combination of the training inputs; the second is an equality constraint on the dual variable.

\begin{theorem}[Hard-margin SVM dual]\label{thm:hard-svm-dual}
The Lagrange dual of the hard-margin SVM primal of Definition~\ref{def:hard-svm} is
\[
\max_{\boldsymbol\lambda \in \mathbb{R}^n}\; \sum_{i=1}^n \lambda_i \;-\; \tfrac{1}{2} \sum_{i=1}^n \sum_{j=1}^n \lambda_i \lambda_j y_i y_j\, \mathbf{x}_i^\top \mathbf{x}_j \quad \text{subject to}\quad \lambda_i \geqslant 0\;\; (i = 1, \ldots, n), \quad \sum_{i=1}^n \lambda_i y_i = 0.
\]
The dual optimal value equals the primal optimal value, $d^\star = p^\star$, and from any dual-optimal $\boldsymbol\lambda^\star$ the primal weight vector is recovered by $\mathbf{w}^\star = \sum_{i=1}^n \lambda_i^\star y_i \mathbf{x}_i$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:hard-svm-dual}]
The Lagrangian is convex in $(\mathbf{w}, b)$ for every fixed $\boldsymbol\lambda \geqslant \mathbf{0}$ (a positive-semi-definite quadratic in $\mathbf{w}$ plus an affine term). The dual function is
\[
g(\boldsymbol\lambda) \;=\; \inf_{\mathbf{w}, b} L(\mathbf{w}, b, \boldsymbol\lambda).
\]
Write $\tilde{\mathbf{x}}(\boldsymbol\lambda) = \sum_i \lambda_i y_i \mathbf{x}_i$ and $c(\boldsymbol\lambda) = \sum_i \lambda_i y_i$. The Lagrangian rewrites as
\[
L \;=\; \tfrac{1}{2}\|\mathbf{w}\|^2 \;-\; \mathbf{w}^\top \tilde{\mathbf{x}}(\boldsymbol\lambda) \;-\; b\, c(\boldsymbol\lambda) \;+\; \sum_i \lambda_i.
\]
The term $-b\, c(\boldsymbol\lambda)$ is linear in $b$. If $c(\boldsymbol\lambda) \neq 0$, sending $b \to \pm \infty$ in the appropriate sign drives $L \to -\infty$, so $g(\boldsymbol\lambda) = -\infty$ and $\boldsymbol\lambda \notin \dom g$.

Restrict to $\boldsymbol\lambda$ with $c(\boldsymbol\lambda) = 0$. The Lagrangian is then constant in $b$ and a strictly convex quadratic in $\mathbf{w}$; its unique minimizer over $\mathbf{w}$ is $\mathbf{w}(\boldsymbol\lambda) = \tilde{\mathbf{x}}(\boldsymbol\lambda)$ (set $\nabla_{\mathbf{w}} L = \mathbf{0}$). Substituting back,
\begin{align*}
g(\boldsymbol\lambda) \;&=\; \tfrac{1}{2}\|\tilde{\mathbf{x}}(\boldsymbol\lambda)\|^2 \;-\; \tilde{\mathbf{x}}(\boldsymbol\lambda)^\top \tilde{\mathbf{x}}(\boldsymbol\lambda) \;+\; \sum_i \lambda_i \\
&=\; -\tfrac{1}{2}\|\tilde{\mathbf{x}}(\boldsymbol\lambda)\|^2 \;+\; \sum_i \lambda_i \\
&=\; \sum_{i=1}^n \lambda_i \;-\; \tfrac{1}{2}\sum_{i=1}^n \sum_{j=1}^n \lambda_i \lambda_j y_i y_j\, \mathbf{x}_i^\top \mathbf{x}_j.
\end{align*}
The dual problem $\max_{\boldsymbol\lambda \geqslant 0} g(\boldsymbol\lambda)$, together with the implicit domain restriction $c(\boldsymbol\lambda) = 0$, is exactly the displayed quadratic program. Theorem~\ref{thm:strong-duality} gives $d^\star = p^\star$, and KKT condition \ref{kkt:stat} at the primal-dual optimum, $\mathbf{w}^\star = \sum_i \lambda_i^\star y_i \mathbf{x}_i$, recovers the primal weight. $\blacksquare$
\end{derivation}

Two features of the dual deserve notice. The objective depends on training inputs only through the inner products $\mathbf{x}_i^\top \mathbf{x}_j$, the slot kernel methods will fill. The constraint set is the nonnegative orthant in $\mathbb{R}^n$ intersected with one affine hyperplane, so the dual is an $n \times n$ convex QP regardless of input dimension $p$.

\subsection{KKT conditions and support vectors}\label{subsec:6.3.2}

The remaining KKT conditions identify which training points actually shape the decision boundary.

\begin{theorem}[KKT for the hard-margin SVM]\label{thm:hard-svm-kkt}
A triple $(\mathbf{w}^\star, b^\star, \boldsymbol\lambda^\star)$ is primal-dual optimal for the hard-margin SVM of Definition~\ref{def:hard-svm} if and only if it satisfies all four KKT conditions of Definition~\ref{def:kkt}, which in this problem read
\begin{enumerate}[label=\textup{(\roman*)},ref=\textup{(\roman*)},leftmargin=2em,itemsep=2pt,topsep=2pt]
\item\label{svm:stat} \textbf{Stationarity}: $\displaystyle \mathbf{w}^\star = \sum_{i=1}^n \lambda_i^\star y_i \mathbf{x}_i$ and $\displaystyle \sum_{i=1}^n \lambda_i^\star y_i = 0$;
\item\label{svm:pfeas} \textbf{Primal feasibility}: $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) \geqslant 1$ for $i = 1, \ldots, n$;
\item\label{svm:dfeas} \textbf{Dual feasibility}: $\lambda_i^\star \geqslant 0$ for $i = 1, \ldots, n$;
\item\label{svm:cs} \textbf{Complementary slackness}: $\lambda_i^\star \big[1 - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)\big] = 0$ for $i = 1, \ldots, n$.
\end{enumerate}
\end{theorem}

The hard-margin problem is convex, differentiable, has only affine inequality constraints, and Slater's condition reduces to feasibility (linear separability). Theorems~\ref{thm:kkt-necessary} and \ref{thm:kkt-sufficient} then apply directly to give the if-and-only-if statement.

\begin{definition}[Support vectors]\label{def:support-vector}
A training point $(\mathbf{x}_i, y_i)$ is a \textbf{support vector} if its multiplier at the dual optimum is strictly positive, $\lambda_i^\star > 0$. The set of indices $\mathcal{S} = \{i : \lambda_i^\star > 0\}$ is the \textbf{support set}.
\end{definition}

Complementary slackness \ref{svm:cs} splits the training points into two groups:
\begin{itemize}[leftmargin=2em,itemsep=2pt,topsep=2pt]
\item if $\lambda_i^\star > 0$ then $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) = 1$: the support vector $\mathbf{x}_i$ lies exactly on the margin boundary;
\item if $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) > 1$ then $\lambda_i^\star = 0$: a strictly-correct point makes no contribution to $\mathbf{w}^\star$.
\end{itemize}

Stationarity \ref{svm:stat} reads $\mathbf{w}^\star = \sum_i \lambda_i^\star y_i \mathbf{x}_i$, which collapses to a sum over support vectors only:
\[
\mathbf{w}^\star \;=\; \sum_{i \in \mathcal{S}} \lambda_i^\star y_i \mathbf{x}_i.
\]
The decision boundary depends on the training data only through the support set; deleting any non-support point from the training set leaves $\mathbf{w}^\star$ and $b^\star$ unchanged.

\paragraph{Recovering $b^\star$.} For any support-vector index $i \in \mathcal{S}$, complementary slackness gives $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) = 1$, hence
\[
b^\star \;=\; y_i - \mathbf{w}^{\star \top} \mathbf{x}_i \;=\; y_i - \sum_{j \in \mathcal{S}} \lambda_j^\star y_j\, \mathbf{x}_j^\top \mathbf{x}_i \qquad (i \in \mathcal{S}),
\]
using $1/y_i = y_i$ for $y_i \in \{-1, +1\}$. Numerical implementations average this expression over all $i \in \mathcal{S}$ to reduce floating-point noise from any single support vector.

\subsection{Margin width and the dual decision function}\label{subsec:6.3.3}

The support-vector characterization of \S\ref{subsec:6.3.2} has two geometric consequences for the maximum-margin classifier.

\paragraph{Margin width.} Under the normalization $\min_i y_i(\mathbf{w}^{\star\top}\mathbf{x}_i + b^\star) = 1$, the decision boundary $\{\mathbf{x} : \mathbf{w}^{\star\top}\mathbf{x} + b^\star = 0\}$ sits between the two parallel margin hyperplanes
\[
H_+ \;=\; \{\mathbf{x} : \mathbf{w}^{\star\top}\mathbf{x} + b^\star = +1\}, \qquad H_- \;=\; \{\mathbf{x} : \mathbf{w}^{\star\top}\mathbf{x} + b^\star = -1\}.
\]
The Euclidean distance between $H_+$ and $H_-$ is $2 / \|\mathbf{w}^\star\|$, the \textbf{margin width}. Maximizing the margin width is therefore equivalent to minimizing $\|\mathbf{w}^\star\|$, recovering the primal objective of Definition~\ref{def:hard-svm}.

\paragraph{Decision function in dual form.} Substituting $\mathbf{w}^\star = \sum_{i \in \mathcal{S}} \lambda_i^\star y_i \mathbf{x}_i$ into the linear classifier yields the prediction function
\[
f^\star(\mathbf{x}) \;=\; \mathbf{w}^{\star\top}\mathbf{x} + b^\star \;=\; \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, \mathbf{x}_i^\top \mathbf{x} \;+\; b^\star, \qquad \hat y(\mathbf{x}) \;=\; \operatorname{sign}\!\big(f^\star(\mathbf{x})\big).
\]
Both training (the dual QP of Theorem~\ref{thm:hard-svm-dual}) and prediction depend on the input data only through inner products $\mathbf{x}_i^\top \mathbf{x}_j$ and $\mathbf{x}_i^\top \mathbf{x}$. Kernel methods exploit this.

\section{Soft-Margin SVM and Hinge Loss}\label{sec:6.4}

The hard-margin SVM requires linearly separable data. Real data rarely is; the soft-margin extension allows individual training points to violate their margin constraint by a controlled amount.

\subsection{Slack variables and the soft-margin primal}\label{subsec:6.4.1}

For each training point $(\mathbf{x}_i, y_i)$, introduce a slack variable $\xi_i \geqslant 0$ measuring how far the point falls short of the margin boundary. The relaxed margin constraint is
\[
y_i(\mathbf{w}^\top \mathbf{x}_i + b) \;\geqslant\; 1 - \xi_i, \qquad \xi_i \geqslant 0.
\]
The value of $\xi_i$ records the violation size:

\begin{ctab}
\begin{tabular}{l c}
\toprule
\textbf{Point status} & \textbf{Slack $\xi_i$} \\
\midrule
Correctly classified, outside margin slab ($y_i(\mathbf{w}^\top \mathbf{x}_i + b) \geqslant 1$) & $0$ \\
Inside margin slab                                                                          & $0 < \xi_i \leqslant 1$ \\
Misclassified (wrong side of decision boundary)                                             & $\xi_i > 1$ \\
\bottomrule
\end{tabular}
\end{ctab}

\begin{definition}[Soft-margin SVM primal]\label{def:soft-svm}
For training data $\{(\mathbf{x}_i, y_i)\}_{i=1}^n$ with $y_i \in \{-1, +1\}$ and a regularization parameter $C > 0$, the \textbf{soft-margin SVM primal} is
\[
\min_{\mathbf{w} \in \mathbb{R}^p,\, b \in \mathbb{R},\, \boldsymbol\xi \in \mathbb{R}^n}\; \tfrac{1}{2}\|\mathbf{w}\|^2 + C \sum_{i=1}^n \xi_i \quad \text{subject to}\quad
\begin{cases} y_i(\mathbf{w}^\top \mathbf{x}_i + b) \geqslant 1 - \xi_i, & i = 1, \ldots, n, \\ \xi_i \geqslant 0, & i = 1, \ldots, n. \end{cases}
\]
\end{definition}

$\tfrac{1}{2}\|\mathbf{w}\|^2$ favours a wide margin; $C \sum_i \xi_i$ penalizes violations. Large $C$ pushes toward few violations and recovers the hard-margin solution as $C \to \infty$ on separable data; small $C$ tolerates more violations for a wider margin.

The problem is convex: a convex-quadratic-plus-linear objective with $2n$ affine inequality constraints and no equalities. Feasibility is automatic ($\mathbf{w} = \mathbf{0}$, $b = 0$, $\xi_i = 1$ gives objective $Cn$); Slater reduces to feasibility for affine constraints (Definition~\ref{def:slater}), so Theorem~\ref{thm:strong-duality} applies for every $C > 0$ and every dataset. The hard-margin's linear-separability requirement is replaced by universal feasibility of slacks: a non-separable dataset is handled at finite cost, with positive $\xi_i^\star$ allocated to inseparable points.

\subsection{Soft-margin dual and the box constraint}\label{subsec:6.4.2}

The Lagrangian carries one nonnegative multiplier per constraint: $\lambda_i \geqslant 0$ for the margin-with-slack constraint and $\mu_i \geqslant 0$ for the slack-nonnegativity constraint $-\xi_i \leqslant 0$:
\[
L(\mathbf{w}, b, \boldsymbol\xi, \boldsymbol\lambda, \boldsymbol\mu) \;=\; \tfrac{1}{2}\|\mathbf{w}\|^2 + C \sum_i \xi_i + \sum_i \lambda_i \big[1 - \xi_i - y_i(\mathbf{w}^\top \mathbf{x}_i + b)\big] - \sum_i \mu_i \xi_i.
\]
Rearranging,
\[
L \;=\; \tfrac{1}{2}\|\mathbf{w}\|^2 - \mathbf{w}^\top \!\sum_i \lambda_i y_i \mathbf{x}_i - b \sum_i \lambda_i y_i + \sum_i \xi_i (C - \lambda_i - \mu_i) + \sum_i \lambda_i.
\]

\begin{theorem}[Soft-margin SVM dual]\label{thm:soft-svm-dual}
The Lagrange dual of the soft-margin SVM primal of Definition~\ref{def:soft-svm} is
\[
\max_{\boldsymbol\lambda \in \mathbb{R}^n}\; \sum_{i=1}^n \lambda_i - \tfrac{1}{2}\sum_{i=1}^n \sum_{j=1}^n \lambda_i \lambda_j y_i y_j\, \mathbf{x}_i^\top \mathbf{x}_j \quad \text{subject to}\quad 0 \leqslant \lambda_i \leqslant C\;\; (i = 1, \ldots, n), \quad \sum_{i=1}^n \lambda_i y_i = 0.
\]
The dual optimal value equals the primal optimal value, $d^\star = p^\star$, and the primal weight vector is recovered by $\mathbf{w}^\star = \sum_{i=1}^n \lambda_i^\star y_i \mathbf{x}_i$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:soft-svm-dual}]
Both $b$ and $\boldsymbol\xi$ enter $L$ linearly; for the inner infimum over them to be finite, the corresponding coefficients must vanish:
\[
\frac{\partial L}{\partial b} \;=\; -\sum_i \lambda_i y_i \;=\; 0, \qquad \frac{\partial L}{\partial \xi_i} \;=\; C - \lambda_i - \mu_i \;=\; 0 \;\text{ for every } i.
\]
If either condition fails, the linear term drives $L$ to $-\infty$ along the appropriate direction in $b$ or $\xi_i$, so the dual point falls outside $\dom g$. The second condition gives $\mu_i = C - \lambda_i$; combined with $\mu_i \geqslant 0$, this produces the upper bound $\lambda_i \leqslant C$, and the slack-nonnegativity multiplier $\boldsymbol\mu$ disappears from the dual.

Setting $\nabla_\mathbf{w} L = \mathbf{0}$ gives $\mathbf{w}(\boldsymbol\lambda) = \sum_i \lambda_i y_i \mathbf{x}_i$. Substituting back, with the slack term $\xi_i (C - \lambda_i - \mu_i)$ identically zero,
\[
g(\boldsymbol\lambda) \;=\; -\tfrac{1}{2}\|\mathbf{w}(\boldsymbol\lambda)\|^2 + \sum_i \lambda_i \;=\; \sum_i \lambda_i - \tfrac{1}{2}\sum_{i, j} \lambda_i \lambda_j y_i y_j\, \mathbf{x}_i^\top \mathbf{x}_j.
\]
The dual problem is $\max_{\boldsymbol\lambda} g(\boldsymbol\lambda)$ over the box $0 \leqslant \lambda_i \leqslant C$ plus the equality constraint $\sum_i \lambda_i y_i = 0$. Theorem~\ref{thm:strong-duality}, whose hypotheses were verified at the close of \S\ref{subsec:6.4.1}, gives $d^\star = p^\star$ and the recovery formula for $\mathbf{w}^\star$. $\blacksquare$
\end{derivation}

The soft-margin dual differs from the hard-margin dual (Theorem~\ref{thm:hard-svm-dual}) only by adding the upper bound $\lambda_i \leqslant C$. As $C \to \infty$, the bound becomes inactive and the dual reduces to the hard-margin one; finite $C$ caps each point's influence on $\mathbf{w}^\star$.

\paragraph{Three classes of training points.} Complementary slackness for the two constraints reads
\[
\lambda_i^\star \big[1 - \xi_i^\star - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)\big] = 0, \qquad \mu_i^\star \xi_i^\star \;=\; (C - \lambda_i^\star)\, \xi_i^\star \;=\; 0.
\]
The pair partitions training points by the value of $\lambda_i^\star$:
\begin{itemize}[leftmargin=2em,itemsep=2pt,topsep=2pt]
\item $\lambda_i^\star = 0$: $\mu_i^\star = C > 0$ forces $\xi_i^\star = 0$, and the margin constraint holds with $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) \geqslant 1$. The point sits outside the margin slab and contributes nothing to $\mathbf{w}^\star$.
\item $0 < \lambda_i^\star < C$ (\textbf{margin support vector}): $\mu_i^\star = C - \lambda_i^\star > 0$ forces $\xi_i^\star = 0$, and the first complementary slackness equation gives $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) = 1$. The point sits exactly on the margin boundary.
\item $\lambda_i^\star = C$ (\textbf{bound support vector}): $\mu_i^\star = 0$ permits $\xi_i^\star \geqslant 0$, and $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) = 1 - \xi_i^\star$. The point sits inside the margin slab when $0 < \xi_i^\star \leqslant 1$ and is misclassified when $\xi_i^\star > 1$.
\end{itemize}

\paragraph{Recovering $b^\star$.} A margin support vector ($0 < \lambda_i^\star < C$) has $\xi_i^\star = 0$ and $y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star) = 1$, hence $b^\star = y_i - \mathbf{w}^{\star \top} \mathbf{x}_i$. Bound support vectors do not pin $b^\star$ because their slack value is not determined directly from $\boldsymbol\lambda^\star$; numerical implementations average the formula over the margin support vectors only.

\subsection{Hinge loss reformulation}\label{subsec:6.4.3}

The soft-margin primal can be rewritten as a regularized empirical risk minimization in $(\mathbf{w}, b)$ alone, with the slack variables eliminated and a specific loss function exposed.

\begin{lemma}[Optimal slack equals hinge loss]\label{lem:slack-hinge}
At any optimum of the soft-margin primal of Definition~\ref{def:soft-svm}, the optimal slack for training point $(\mathbf{x}_i, y_i)$ is
\[
\xi_i^\star \;=\; \big[1 - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)\big]_+ \;=\; \max\!\big(0,\; 1 - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)\big).
\]
\end{lemma}

\begin{derivation}[Proof of Lemma~\ref{lem:slack-hinge}]
Fix $(\mathbf{w}^\star, b^\star)$ at the optimum. The slack $\xi_i$ enters the primal only through the term $C \xi_i$ in the objective and the per-point constraints $\xi_i \geqslant 0$ and $\xi_i \geqslant 1 - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)$. With $C > 0$, minimizing the objective in $\xi_i$ alone (the other variables fixed) is achieved at the smallest feasible value, which is $\max\big(0,\; 1 - y_i(\mathbf{w}^{\star \top} \mathbf{x}_i + b^\star)\big)$. $\blacksquare$
\end{derivation}

\begin{definition}[Hinge loss]\label{def:hinge-loss}
The \textbf{hinge loss} for binary classification with labels $y \in \{-1, +1\}$ and a real-valued score $f(\mathbf{x})$ is
\[
\ell_{\mathrm{hinge}}(y, f(\mathbf{x})) \;=\; \big[1 - y\, f(\mathbf{x})\big]_+ \;=\; \max\!\big(0,\; 1 - y\, f(\mathbf{x})\big).
\]
The loss is zero on points classified correctly with score magnitude at least $1$; for $y f(\mathbf{x}) < 1$ the loss grows linearly in the gap.
\end{definition}

Substituting Lemma~\ref{lem:slack-hinge} into the soft-margin primal eliminates $\boldsymbol\xi$ and yields an equivalent unconstrained reformulation:
\[
\min_{\mathbf{w} \in \mathbb{R}^p,\, b \in \mathbb{R}}\; \tfrac{1}{2}\|\mathbf{w}\|^2 \;+\; C \sum_{i=1}^n \big[1 - y_i(\mathbf{w}^\top \mathbf{x}_i + b)\big]_+.
\]
This is regularized empirical risk minimization: the per-point hinge loss summed over the training set, plus an $\ell_2$ regularizer on $\mathbf{w}$. Dividing through by $Cn$ rewrites the objective in the more familiar regularized-risk form
\[
\frac{1}{n}\sum_{i=1}^n \big[1 - y_i(\mathbf{w}^\top \mathbf{x}_i + b)\big]_+ \;+\; \frac{1}{2 C n}\, \|\mathbf{w}\|^2,
\]
in which the regularization weight is $1/(2 C n)$, decreasing in $C$.

\paragraph{Comparison with other classification losses.} The hinge loss is one of three convex surrogates for the intractable $0/1$ loss seen in this course:

\begin{ctab}
\begin{tabular}{l l l}
\toprule
\textbf{Loss} & \textbf{Formula at score $f(\mathbf{x})$} & \textbf{Differentiable?} \\
\midrule
$0/1$ loss     & $\indc\{y f(\mathbf{x}) < 0\}$                       & no, non-convex \\
Logistic loss  & $\log\!\big(1 + \exp(-y f(\mathbf{x}))\big)$         & yes, convex \\
Hinge loss     & $\big[1 - y f(\mathbf{x})\big]_+$                    & no (kink at $y f = 1$), convex \\
\bottomrule
\end{tabular}
\end{ctab}

\noindent Logistic loss (Unit~3 \S 3.1.3) is smooth, fitting gradient methods in the primal. Hinge loss has a kink at $yf(\mathbf{x}) = 1$: the primal is non-differentiable, but the dual (Theorem~\ref{thm:soft-svm-dual}) is a smooth QP. Standard SVM solvers exploit this asymmetry by solving the dual.

\section{Kernels}\label{sec:6.5}

The dual of the soft-margin SVM (Theorem~\ref{thm:soft-svm-dual}) depends on the input data only through the pairwise inner products $\mathbf{x}_i^\top \mathbf{x}_j$. Replacing those inner products with a more expressive symmetric function of $\mathbf{x}_i$ and $\mathbf{x}_j$ extends the SVM to nonlinear decision boundaries without changing the optimization problem's size.

\subsection{Feature maps and the kernel trick}\label{subsec:6.5.1}

\begin{definition}[Feature map]\label{def:feature-map}
A \textbf{feature map} from input space $\mathbb{R}^p$ to feature space $\mathbb{R}^N$ is a function $\phi : \mathbb{R}^p \to \mathbb{R}^N$ with $N$ possibly $\gg p$. The induced classifier searches for a separating hyperplane in feature space:
\[
f(\mathbf{x}) \;=\; \mathbf{w}^\top \phi(\mathbf{x}) + b, \qquad \mathbf{w} \in \mathbb{R}^N,\; b \in \mathbb{R}.
\]
\end{definition}

The soft-margin SVM in the feature space replaces each $\mathbf{x}_i$ by $\phi(\mathbf{x}_i)$ and each inner product $\mathbf{x}_i^\top \mathbf{x}_j$ by $\phi(\mathbf{x}_i)^\top \phi(\mathbf{x}_j)$. The dual of Theorem~\ref{thm:soft-svm-dual} becomes
\[
\max_{\boldsymbol\lambda}\; \sum_i \lambda_i - \tfrac{1}{2}\sum_{i, j} \lambda_i \lambda_j y_i y_j\, \phi(\mathbf{x}_i)^\top \phi(\mathbf{x}_j) \quad \text{subject to } 0 \leqslant \lambda_i \leqslant C,\; \sum_i \lambda_i y_i = 0,
\]
and the prediction function evaluates as $f^\star(\mathbf{x}) = \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, \phi(\mathbf{x}_i)^\top \phi(\mathbf{x}) + b^\star$.

\begin{definition}[Kernel function]\label{def:kernel}
For a feature map $\phi : \mathbb{R}^p \to \mathbb{R}^N$, the associated \textbf{kernel function} is
\[
K : \mathbb{R}^p \times \mathbb{R}^p \to \mathbb{R}, \qquad K(\mathbf{x}, \mathbf{x}') \;=\; \phi(\mathbf{x})^\top \phi(\mathbf{x}').
\]
\end{definition}

The dual SVM and the prediction function depend on $\phi$ only through $K$. Whenever $K$ can be evaluated more cheaply than via the explicit feature vectors $\phi(\mathbf{x}), \phi(\mathbf{x}')$, the SVM extends to high-dimensional feature spaces at no additional optimization cost. This computational shortcut is the \textbf{kernel trick}.

\begin{example}[Quadratic kernel on $\mathbb{R}^2$]\label{ex:poly-feature}
Take $\mathbf{x}, \mathbf{x}' \in \mathbb{R}^2$ and define
\[
\phi(\mathbf{x}) \;=\; (x_1^2,\; x_2^2,\; \sqrt{2}\,x_1 x_2,\; \sqrt{2}\,x_1,\; \sqrt{2}\,x_2,\; 1)^\top \;\in\; \mathbb{R}^6.
\]
Expanding $(\mathbf{x}^\top \mathbf{x}' + 1)^2$ in the variables $x_1, x_2, x_1', x_2'$ and matching term-by-term against $\phi(\mathbf{x})^\top \phi(\mathbf{x}')$ confirms
\[
\phi(\mathbf{x})^\top \phi(\mathbf{x}') \;=\; (\mathbf{x}^\top \mathbf{x}' + 1)^2.
\]
The kernel $K(\mathbf{x}, \mathbf{x}') = (\mathbf{x}^\top \mathbf{x}' + 1)^2$ evaluates a 6-dimensional inner product at the cost of one 2-dimensional inner product and a squaring. The cost saving generalizes: a degree-$d$ polynomial kernel on $\mathbb{R}^p$ corresponds to a feature map into a space of dimension $\binom{p+d}{d}$, evaluated in $O(p)$ time per pair instead of $O\!\big(\binom{p+d}{d}\big)$.
\end{example}

\begin{suppremark}[Infinite-dimensional feature spaces]
The Gaussian RBF kernel $K(\mathbf{x}, \mathbf{x}') = \exp(-\gamma \|\mathbf{x} - \mathbf{x}'\|^2)$ corresponds to a feature map into an \emph{infinite}-dimensional reproducing kernel Hilbert space (RKHS). The dual hides the infinite-dimensional construction: every quantity needed for training and prediction goes through $K$, and the PSD condition (next subsection) guarantees that $\phi$ exists.
\end{suppremark}

The kernel trick decouples training cost from the feature-space dimension. The next subsection identifies which symmetric functions $K$ arise from some feature map.

\subsection{The PSD condition for kernels}\label{subsec:6.5.2}

Not every symmetric function $K : \mathbb{R}^p \times \mathbb{R}^p \to \mathbb{R}$ arises as an inner product in some feature space. The function must be \textbf{positive semi-definite}.

\begin{definition}[Positive-semi-definite kernel]\label{def:psd-kernel}
A symmetric function $K : \mathbb{R}^p \times \mathbb{R}^p \to \mathbb{R}$ is a \textbf{positive-semi-definite (PSD) kernel} if for every finite set $\{\mathbf{x}_1, \ldots, \mathbf{x}_n\} \subset \mathbb{R}^p$ the Gram matrix
\[
\mathbf{K} \;=\; \big[K(\mathbf{x}_i, \mathbf{x}_j)\big]_{i, j = 1}^{n} \;\in\; \mathbb{R}^{n \times n}
\]
is symmetric positive semi-definite (Unit~1, the PSD definition).
\end{definition}

The PSD condition is necessary for $K$ to express an inner product. If $K(\mathbf{x}, \mathbf{x}') = \phi(\mathbf{x})^\top \phi(\mathbf{x}')$, then for any vector $\mathbf{c} \in \mathbb{R}^n$,
\[
\mathbf{c}^\top \mathbf{K} \mathbf{c} \;=\; \sum_{i, j} c_i c_j\, \phi(\mathbf{x}_i)^\top \phi(\mathbf{x}_j) \;=\; \Big\|\sum_i c_i \phi(\mathbf{x}_i)\Big\|^2 \;\geqslant\; 0.
\]
The converse holds on every finite training set, via spectral decomposition.

\begin{theorem}[Finite-sample feature map]\label{thm:gram-feature}
Let $K$ be a PSD kernel and $\{\mathbf{x}_1, \ldots, \mathbf{x}_n\} \subset \mathbb{R}^p$ any finite training set. The Gram matrix decomposes as $\mathbf{K} = \mathbf{V}\boldsymbol\Lambda \mathbf{V}^\top$ with $\mathbf{V} \in \mathbb{R}^{n \times n}$ orthogonal and $\boldsymbol\Lambda = \diag(\lambda_1, \ldots, \lambda_n)$, $\lambda_i \geqslant 0$. Setting $\boldsymbol\Phi = \mathbf{V} \boldsymbol\Lambda^{1/2} \in \mathbb{R}^{n \times n}$, the rows of $\boldsymbol\Phi$ act as feature vectors for the training set:
\[
K(\mathbf{x}_i, \mathbf{x}_j) \;=\; \boldsymbol\Phi_i^\top \boldsymbol\Phi_j, \qquad i, j = 1, \ldots, n.
\]
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:gram-feature}]
The Gram matrix $\mathbf{K}$ is symmetric PSD by hypothesis, so spectral decomposition gives $\mathbf{K} = \mathbf{V}\boldsymbol\Lambda \mathbf{V}^\top$ with $\mathbf{V}$ orthogonal and $\boldsymbol\Lambda$ diagonal nonnegative. Then
\[
\mathbf{K} \;=\; \mathbf{V} \boldsymbol\Lambda^{1/2} \boldsymbol\Lambda^{1/2} \mathbf{V}^\top \;=\; \boldsymbol\Phi \boldsymbol\Phi^\top,
\]
and $K_{ij} = (\boldsymbol\Phi \boldsymbol\Phi^\top)_{ij} = \boldsymbol\Phi_i^\top \boldsymbol\Phi_j$. $\blacksquare$
\end{derivation}

The theorem says PSD is sufficient on every finite training set: the SVM dual with PSD kernel $K$ has the form
\[
\max_{\boldsymbol\lambda}\; \sum_i \lambda_i - \tfrac{1}{2}\, \boldsymbol\lambda^\top \mathbf{Y} \mathbf{K} \mathbf{Y} \boldsymbol\lambda \quad \text{subject to } 0 \leqslant \lambda_i \leqslant C, \;\sum_i \lambda_i y_i = 0,
\]
where $\mathbf{Y} = \diag(y_1, \ldots, y_n)$. The matrix $\mathbf{Y}\mathbf{K}\mathbf{Y}$ is PSD whenever $\mathbf{K}$ is, so the dual objective is concave and the dual is a convex QP solvable by off-the-shelf solvers. The infinite-dimensional feature map underlying (for example) the RBF kernel is invisible to the solver, which works exclusively with the $n \times n$ Gram matrix.

\paragraph{Common kernels.}

\begin{ctab}
\begin{tabular}{l l l}
\toprule
\textbf{Kernel} & \textbf{Formula} & \textbf{Feature space} \\
\midrule
Linear      & $K(\mathbf{x}, \mathbf{x}') = \mathbf{x}^\top \mathbf{x}'$                                                            & $\mathbb{R}^p$, the input space itself \\
Polynomial  & $K(\mathbf{x}, \mathbf{x}') = (\mathbf{x}^\top \mathbf{x}' + c)^d$, $c \geqslant 0$, $d \in \mathbb{N}$                & finite, $\binom{p+d}{d}$-dim \\
RBF         & $K(\mathbf{x}, \mathbf{x}') = \exp\!\big(-\gamma \|\mathbf{x} - \mathbf{x}'\|^2\big)$, $\gamma > 0$                  & infinite-dimensional \\
\bottomrule
\end{tabular}
\end{ctab}

\noindent The polynomial kernel admits an explicit feature map (Example~\ref{ex:poly-feature} gives the $p = 2, d = 2$ case). The RBF kernel does not admit a finite-dimensional explicit feature map. To establish that the RBF Gram matrix is PSD for every finite training set, we record closure properties of PSD matrices and assemble the RBF kernel from them.

\begin{lemma}[Closure properties of PSD matrices]\label{lem:psd-closure}
Let $\mathbf{A}, \mathbf{B} \in \mathbb{R}^{n \times n}$ be symmetric PSD.
\begin{enumerate}
\item[(i)] (Sum.) $\mathbf{A} + \mathbf{B}$ is PSD.
\item[(ii)] (Schur product theorem.) The entrywise product $\mathbf{A} \circ \mathbf{B}$, defined by $(\mathbf{A}\circ\mathbf{B})_{ij} = A_{ij} B_{ij}$, is PSD.
\item[(iii)] (Outer rescaling.) For any $\mathbf{g} \in \mathbb{R}^n$, the matrix with entries $g_i A_{ij} g_j$ is PSD.
\item[(iv)] (Entrywise limits.) If $\mathbf{A}_k$ is PSD for every $k$ and $\mathbf{A}_k \to \mathbf{A}$ entrywise, then $\mathbf{A}$ is PSD.
\end{enumerate}
\end{lemma}

\begin{derivation}[Proof of Lemma~\ref{lem:psd-closure}]
(i) $\mathbf{v}^\top(\mathbf{A}+\mathbf{B})\mathbf{v} = \mathbf{v}^\top\mathbf{A}\mathbf{v} + \mathbf{v}^\top\mathbf{B}\mathbf{v} \geqslant 0$.

(ii) Spectral decomposition gives $\mathbf{A} = \sum_r \mathbf{u}_r \mathbf{u}_r^\top$ and $\mathbf{B} = \sum_s \mathbf{w}_s \mathbf{w}_s^\top$ with the nonnegative eigenvalues absorbed into the vectors. Then
\[
A_{ij} B_{ij} \;=\; \sum_{r,s} u_{r,i} u_{r,j} w_{s,i} w_{s,j} \;=\; \sum_{r,s} (u_{r,i} w_{s,i})(u_{r,j} w_{s,j}),
\]
so $\mathbf{A} \circ \mathbf{B} = \sum_{r,s} \mathbf{z}_{rs} \mathbf{z}_{rs}^\top$ with $\mathbf{z}_{rs} = \mathbf{u}_r \circ \mathbf{w}_s$, a nonnegative sum of rank-one PSD matrices.

(iii) Let $\mathbf{A}'$ have entries $A'_{ij} = g_i A_{ij} g_j$. Then $\mathbf{v}^\top \mathbf{A}' \mathbf{v} = \sum_{ij} (v_i g_i)\, A_{ij}\, (v_j g_j) = (\mathbf{g}\circ\mathbf{v})^\top \mathbf{A} (\mathbf{g}\circ\mathbf{v}) \geqslant 0$.

(iv) For fixed $\mathbf{v}$, $\mathbf{v}^\top \mathbf{A}_k \mathbf{v} \geqslant 0$ for every $k$, and the sequence converges to $\mathbf{v}^\top \mathbf{A} \mathbf{v}$; the limit is therefore nonnegative. $\blacksquare$
\end{derivation}

\begin{theorem}[The RBF kernel is PSD]\label{thm:rbf-psd}
For every $\gamma > 0$ and every finite $\{\mathbf{x}_1, \ldots, \mathbf{x}_n\} \subset \mathbb{R}^p$, the Gram matrix $K_{ij} = \exp(-\gamma \|\mathbf{x}_i - \mathbf{x}_j\|^2)$ is positive semi-definite.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:rbf-psd}]
Expand $\|\mathbf{x}_i - \mathbf{x}_j\|^2 = \|\mathbf{x}_i\|^2 - 2\,\mathbf{x}_i^\top \mathbf{x}_j + \|\mathbf{x}_j\|^2$, so
\[
K_{ij} \;=\; e^{-\gamma\|\mathbf{x}_i\|^2}\; e^{2\gamma\,\mathbf{x}_i^\top \mathbf{x}_j}\; e^{-\gamma\|\mathbf{x}_j\|^2}.
\]
Set $g_i = e^{-\gamma\|\mathbf{x}_i\|^2}$ and $M_{ij} = e^{2\gamma\,\mathbf{x}_i^\top \mathbf{x}_j}$, giving $K_{ij} = g_i M_{ij} g_j$. By Lemma~\ref{lem:psd-closure}(iii) it suffices to show $\mathbf{M}$ is PSD.

The linear-kernel matrix $L_{ij} = \mathbf{x}_i^\top \mathbf{x}_j$ is the Gram matrix of the identity feature map and is PSD. For each integer $m \geqslant 1$, the entrywise power $L^{\circ m}_{ij} = L_{ij}^m$ is PSD by $(m-1)$ applications of Lemma~\ref{lem:psd-closure}(ii); the $m = 0$ case is the all-ones matrix $\mathbf{1}\mathbf{1}^\top$, also PSD. The exponential admits the entrywise convergent expansion
\[
M_{ij} \;=\; \sum_{m=0}^{\infty} \frac{(2\gamma)^m}{m!}\, L_{ij}^m.
\]
Every partial sum is a nonnegative combination of PSD matrices, hence PSD by Lemma~\ref{lem:psd-closure}(i); the entrywise limit $\mathbf{M}$ is PSD by Lemma~\ref{lem:psd-closure}(iv). Therefore $\mathbf{K}$ is PSD. $\blacksquare$
\end{derivation}

\noindent The hyperparameter $\gamma$ controls locality: small $\gamma$ approaches a constant kernel (every pair looks similar); large $\gamma$ concentrates near the diagonal (every pair looks dissimilar unless near-coincident).

\subsection{Representer theorem}\label{subsec:6.5.3}

The representer theorem states that the optimal weight vector of any kernel-based regularized risk minimization lies in the span of the training feature vectors. The optimization therefore reduces to choosing $n$ coefficients, independent of the feature-space dimension. The proof rests on a linear-algebra fact about orthogonal decomposition.

\begin{lemma}[Orthogonal decomposition]\label{lem:orth-decomp}
For any subspace $\mathcal{V} \subseteq \mathbb{R}^N$ and any $\mathbf{w} \in \mathbb{R}^N$, there is a unique decomposition
\[
\mathbf{w} \;=\; \mathbf{w}_\parallel + \mathbf{w}_\perp, \qquad \mathbf{w}_\parallel \in \mathcal{V},\;\; \mathbf{w}_\perp \in \mathcal{V}^\perp \;=\; \{\mathbf{u} \in \mathbb{R}^N : \mathbf{u}^\top \mathbf{v} = 0\;\forall \mathbf{v} \in \mathcal{V}\}.
\]
It satisfies $\mathbf{w}_\parallel^\top \mathbf{w}_\perp = 0$ and the Pythagorean identity $\|\mathbf{w}\|^2 = \|\mathbf{w}_\parallel\|^2 + \|\mathbf{w}_\perp\|^2$.
\end{lemma}

\begin{derivation}[Proof of Lemma~\ref{lem:orth-decomp}]
Let $\{\mathbf{v}_1, \ldots, \mathbf{v}_k\}$ be an orthonormal basis of $\mathcal{V}$, obtained from any spanning set by Gram--Schmidt. Set
\[
\mathbf{w}_\parallel \;=\; \sum_{j=1}^k (\mathbf{w}^\top \mathbf{v}_j)\, \mathbf{v}_j, \qquad \mathbf{w}_\perp \;=\; \mathbf{w} - \mathbf{w}_\parallel.
\]
Then $\mathbf{w}_\parallel \in \mathcal{V}$ by construction, and $\mathbf{w}_\perp^\top \mathbf{v}_j = \mathbf{w}^\top \mathbf{v}_j - \mathbf{w}^\top \mathbf{v}_j = 0$ for every $j$, so $\mathbf{w}_\perp \in \mathcal{V}^\perp$. For uniqueness, suppose $\mathbf{w} = \mathbf{u}_\parallel + \mathbf{u}_\perp$ is another such decomposition; then $\mathbf{w}_\parallel - \mathbf{u}_\parallel = \mathbf{u}_\perp - \mathbf{w}_\perp \in \mathcal{V} \cap \mathcal{V}^\perp$, and any $\mathbf{v} \in \mathcal{V} \cap \mathcal{V}^\perp$ satisfies $\mathbf{v}^\top \mathbf{v} = 0$ hence $\mathbf{v} = \mathbf{0}$. The Pythagorean identity follows from $\|\mathbf{w}_\parallel + \mathbf{w}_\perp\|^2 = \|\mathbf{w}_\parallel\|^2 + 2\mathbf{w}_\parallel^\top \mathbf{w}_\perp + \|\mathbf{w}_\perp\|^2$ using $\mathbf{w}_\parallel^\top \mathbf{w}_\perp = 0$. $\blacksquare$
\end{derivation}

\begin{theorem}[Representer theorem]\label{thm:representer}
Let $\phi : \mathbb{R}^p \to \mathbb{R}^N$ be a feature map (with $N$ possibly large). Consider the regularized risk minimization
\[
\min_{\mathbf{w} \in \mathbb{R}^N,\, b \in \mathbb{R}}\; \tfrac{1}{2}\|\mathbf{w}\|^2 \;+\; \sum_{i=1}^n L\!\big(y_i,\; \mathbf{w}^\top \phi(\mathbf{x}_i) + b\big),
\]
where $L$ is any loss function (no convexity, smoothness, or sign assumptions). Every optimum $\mathbf{w}^\star$ admits the representation
\[
\mathbf{w}^\star \;=\; \sum_{i=1}^n \alpha_i\, \phi(\mathbf{x}_i)
\]
for some coefficients $\alpha_1, \ldots, \alpha_n \in \mathbb{R}$.
\end{theorem}

\begin{derivation}[Proof of Theorem~\ref{thm:representer}]
Let $\mathcal{V} = \mathrm{span}\{\phi(\mathbf{x}_1), \ldots, \phi(\mathbf{x}_n)\} \subseteq \mathbb{R}^N$, a subspace of dimension at most $n$. By Lemma~\ref{lem:orth-decomp}, every $\mathbf{w} \in \mathbb{R}^N$ has a unique decomposition $\mathbf{w} = \mathbf{w}_\parallel + \mathbf{w}_\perp$ with $\mathbf{w}_\parallel \in \mathcal{V}$, $\mathbf{w}_\perp \in \mathcal{V}^\perp$. The prediction at every training point uses only the parallel component:
\[
\mathbf{w}^\top \phi(\mathbf{x}_i) \;=\; \mathbf{w}_\parallel^\top \phi(\mathbf{x}_i) + \mathbf{w}_\perp^\top \phi(\mathbf{x}_i) \;=\; \mathbf{w}_\parallel^\top \phi(\mathbf{x}_i),
\]
where the second equality uses $\phi(\mathbf{x}_i) \in \mathcal{V}$ and $\mathbf{w}_\perp \perp \mathcal{V}$. The fitting sum $\sum_i L(y_i, \mathbf{w}^\top \phi(\mathbf{x}_i) + b)$ therefore depends only on $\mathbf{w}_\parallel$, not on $\mathbf{w}_\perp$.

The regularizer obeys $\|\mathbf{w}\|^2 = \|\mathbf{w}_\parallel\|^2 + \|\mathbf{w}_\perp\|^2 \geqslant \|\mathbf{w}_\parallel\|^2$, with equality if and only if $\mathbf{w}_\perp = \mathbf{0}$. If $\mathbf{w}^\star$ were optimal with $\mathbf{w}_\perp^\star \neq \mathbf{0}$, replacing it by $\mathbf{w}_\parallel^\star$ would leave the fitting term unchanged and strictly decrease the regularizer, strictly improving the objective: contradiction. Hence $\mathbf{w}_\perp^\star = \mathbf{0}$ at every optimum, and $\mathbf{w}^\star \in \mathcal{V}$. By definition of $\mathcal{V}$, $\mathbf{w}^\star = \sum_i \alpha_i \phi(\mathbf{x}_i)$ for some $\boldsymbol\alpha \in \mathbb{R}^n$. $\blacksquare$
\end{derivation}

Two consequences. First, the optimum lives in an at-most-$n$-dimensional subspace pinned by the training data, regardless of the feature space's nominal dimension; this is what makes the kernel trick computationally feasible. Second, the same conclusion applies to ridge regression, kernel ridge regression, kernel logistic regression, and any other regularized risk minimization sharing the squared-norm regularizer; the loss function's identity does not enter the proof.

\begin{suppremark}[Reproducing kernel Hilbert spaces]
The proof uses only the inner-product and orthogonal-decomposition structure, which carry over to any separable Hilbert space. Applied to the reproducing kernel Hilbert space (RKHS) attached to a PSD kernel $K$, the theorem becomes the version stated in \citet{scholkopf-smola-2002}: every optimum of the RKHS-regularized problem has $\mathbf{w}^\star = \sum_i \alpha_i K(\mathbf{x}_i, \cdot)$. The infinite-dimensional construction is hidden behind the kernel, exactly as in \S\ref{subsec:6.5.2}.
\end{suppremark}

\subsection{Kernel SVM in the dual}\label{subsec:6.5.4}

Combining \S\S\ref{subsec:6.5.1}--\ref{subsec:6.5.3}: the soft-margin SVM with feature map $\phi$ corresponding to a PSD kernel $K$ has dual problem
\[
\max_{\boldsymbol\lambda \in \mathbb{R}^n}\; \sum_{i=1}^n \lambda_i \;-\; \tfrac{1}{2}\sum_{i=1}^n \sum_{j=1}^n \lambda_i \lambda_j y_i y_j\, K(\mathbf{x}_i, \mathbf{x}_j) \quad \text{subject to } 0 \leqslant \lambda_i \leqslant C,\; \sum_{i=1}^n \lambda_i y_i = 0,
\]
and prediction function
\[
f^\star(\mathbf{x}) \;=\; \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, K(\mathbf{x}_i, \mathbf{x}) \;+\; b^\star, \qquad \hat y(\mathbf{x}) \;=\; \operatorname{sign}\!\big(f^\star(\mathbf{x})\big).
\]
The intercept $b^\star$ is recovered from any margin support vector $i$ (one with $0 < \lambda_i^\star < C$):
\[
b^\star \;=\; y_i \;-\; \sum_{j \in \mathcal{S}} \lambda_j^\star y_j\, K(\mathbf{x}_j, \mathbf{x}_i).
\]

The kernel SVM is the linear SVM with $\mathbf{x}_i^\top \mathbf{x}_j$ replaced by $K(\mathbf{x}_i, \mathbf{x}_j)$ everywhere inner products appear (Gram matrix, prediction, $b^\star$ recovery). The feature map $\phi$ is never accessed; the algorithm operates only on $K$ values and training labels.

\paragraph{Why this works.} The representer theorem (Theorem~\ref{thm:representer}) underwrites the substitution. The optimal feature-space weight vector
\[
\mathbf{w}^\star \;=\; \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, \phi(\mathbf{x}_i)
\]
lies in the span of training feature vectors, so $\mathbf{w}^{\star\top} \phi(\mathbf{x}) = \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, \phi(\mathbf{x}_i)^\top \phi(\mathbf{x}) = \sum_{i \in \mathcal{S}} \lambda_i^\star y_i\, K(\mathbf{x}_i, \mathbf{x})$ depends only on $K$ and the training data. The PSD condition (Definition~\ref{def:psd-kernel}) ensures the dual is a convex QP, and strong duality (Theorem~\ref{thm:strong-duality}, applied in the feature space) ensures the dual optimum equals the primal optimum.

\paragraph{Computational cost.} The dual is an $n \times n$ QP, independent of $N$. Training is dominated by the Gram matrix in $O(n^2 \tau(K))$ time and $O(n^2)$ memory, where $\tau(K)$ is the per-pair kernel cost; prediction takes $O(|\mathcal{S}|\, \tau(K))$ per point. The SVM suits small to moderate $n$ with large $N$. The $O(n^2)$ memory becomes the binding constraint around $n \sim 10^4$--$10^5$, past which kernel methods scale only via approximations (random Fourier features, Nystr\"om) or yield to deep learning.

\section{Neural Networks}\label{sec:6.6}

A neural network is a parametrized nonlinear function $f(\mathbf{x}; \boldsymbol\theta)$ obtained by alternating affine maps with elementwise nonlinearities. Training fits $\boldsymbol\theta$ by stochastic gradient descent on a non-convex empirical risk; each iteration requires $\nabla_{\boldsymbol\theta} L$ over a parameter vector with $10^7$ or more entries. \textbf{Backpropagation} is reverse-mode automatic differentiation specialized to the layered composition: it returns $\nabla_{\boldsymbol\theta} L$ at the cost of one extra forward pass.

\subsection{The multilayer perceptron and forward propagation}\label{subsec:6.6.1}

\begin{definition}[$L$-layer multilayer perceptron]\label{def:mlp}
Fix layer widths $d_0 = p,\, d_1, \ldots, d_L$. The \textbf{$L$-layer multilayer perceptron} (MLP) is the function $f : \mathbb{R}^p \to \mathbb{R}^{d_L}$ defined by
\[
\mathbf{a}^{(0)} \;=\; \mathbf{x}, \qquad \mathbf{z}^{(l)} \;=\; \mathbf{W}^{(l)} \mathbf{a}^{(l-1)} + \mathbf{b}^{(l)}, \qquad \mathbf{a}^{(l)} \;=\; \sigma\!\big(\mathbf{z}^{(l)}\big), \qquad l = 1, \ldots, L.
\]
The parameters are $\boldsymbol\theta = \{\mathbf{W}^{(l)} \in \mathbb{R}^{d_l \times d_{l-1}},\; \mathbf{b}^{(l)} \in \mathbb{R}^{d_l}\}_{l=1}^L$, the activation $\sigma : \mathbb{R} \to \mathbb{R}$ is applied componentwise, and the output is $f(\mathbf{x}; \boldsymbol\theta) = \mathbf{a}^{(L)}$.
\end{definition}

\begin{figure}[!htbp]
\centering
\begin{tikzpicture}[
  scale=0.78, every node/.style={transform shape},
  >=stealth,
  neuron/.style={circle, draw, minimum size=8mm, inner sep=0pt, thick}
]
\node[neuron, fill=blue!8]   (a01) at (0, 1.8)  {$x_1$};
\node[neuron, fill=blue!8]   (a02) at (0, 0)    {$x_2$};
\node[neuron, fill=blue!8]   (a03) at (0,-1.8)  {$x_3$};
\node[neuron, fill=green!10] (a11) at (3, 2.7)  {};
\node[neuron, fill=green!10] (a12) at (3, 0.9)  {};
\node[neuron, fill=green!10] (a13) at (3,-0.9)  {};
\node[neuron, fill=green!10] (a14) at (3,-2.7)  {};
\node[neuron, fill=green!10] (a21) at (6, 2.7)  {};
\node[neuron, fill=green!10] (a22) at (6, 0.9)  {};
\node[neuron, fill=green!10] (a23) at (6,-0.9)  {};
\node[neuron, fill=green!10] (a24) at (6,-2.7)  {};
\node[neuron, fill=red!10]   (a31) at (9, 0.9)  {};
\node[neuron, fill=red!10]   (a32) at (9,-0.9)  {};
