  \draw[->, gray!50, thin] (a0\i) -- (a1\j);
\foreach \i in {1,2,3,4} \foreach \j in {1,2,3,4}
  \draw[->, gray!50, thin] (a1\i) -- (a2\j);
\foreach \i in {1,2,3,4} \foreach \j in {1,2}
  \draw[->, gray!50, thin] (a2\i) -- (a3\j);
\node[font=\small] at (0,-3.6) {$\mathbf{a}^{(0)} = \mathbf{x}$};
\node[font=\small] at (3,-3.6) {$\mathbf{a}^{(1)}$};
\node[font=\small] at (6,-3.6) {$\mathbf{a}^{(2)}$};
\node[font=\small] at (9,-3.6) {$\mathbf{a}^{(3)} = f(\mathbf{x};\boldsymbol\theta)$};
